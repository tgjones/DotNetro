; MOS6502 runtime — hand-written MIR loaded as an embedded resource by
; MOS6502Target.GetRuntime(). Functions here are appended to the MirModule
; produced by IL→MIR translation so the resulting program links.

; Indirect-call trampoline. MOS6502CallLowering.LowerIndirectCall parks the
; target address in RC30/RC31 (zero-page bytes $1E/$1F) and emits
; `jsr.abs @__call_indirect_trampoline`. The trampoline then dispatches via
; `JMP ($1E)`, which reads the 16-bit target from $001E/$001F.
func @__call_indirect_trampoline : () -> void {
bb0():
    mos6502.jmp.ind 30
}

; ---------------------------------------------------------------------------
; BBC Micro OS-call wrappers.
;
; These are inherently target-specific: they JSR a fixed ROM vector. There is
; no generic "call ROM address" op, so the bodies are written directly in
; mos6502 MIR (jsr.abs to a numeric absolute address + rts). The char/args
; arrive in $a/$x/$y per CC_MOS; AbiLowering records them as block live-ins
; and, because nothing between the live-in and the JSR clobbers those
; registers, they are preserved into the ROM call unchanged.

; @oswrch — write the char in the first i8 arg ($a) to output. JSR $FFEE.
func @oswrch : (i8) -> void {
bb0(%0 : i8):
    mos6502.jsr.abs 65518
    mos6502.rts
}

; @osasci — like @oswrch but expands CR to CR/LF. JSR $FFE3.
func @osasci : (i8) -> void {
bb0(%0 : i8):
    mos6502.jsr.abs 65507
    mos6502.rts
}

; @osword — OS call dispatcher. JSR $FFF1. Callers set up A (call number),
; X (control-block low byte) and Y (control-block high byte) before calling;
; CC_MOS only assigns A/X here, so the Y argument is the caller's concern.
func @osword : (i8) -> void {
bb0(%0 : i8):
    mos6502.jsr.abs 65521
    mos6502.rts
}

; ---------------------------------------------------------------------------
; @WriteLineBoolean : (i8) -> void
;
; Prints "True" or "False" (each followed by CR, expanded to CR/LF by osasci)
; depending on whether the argument is non-zero. Mirrors
; DotNetro.Runtime.ConsoleHelper.WriteLineBoolean.
;
; Written in generic MIR: an `arith.cmpi ne` against 0 fused with `cf.cond_br`
; picks the leg, and each leg loads the address of the matching string global
; (@True_String / @False_String, registered by the translator in the same
; CR+NUL format @WriteLineString consumes) and tail-calls @WriteLineString.
func @WriteLineBoolean : (i8) -> void {
bb0(%0 : i8):
    %1 : i8 = arith.constant 0
    %2 : i1 = arith.cmpi ne, %0, %1
    cf.cond_br %2, bb1, bb2
bb1():
    %3 : i16 = mem.symbol @True_String
    call.func @WriteLineString, %3
    core.return
bb2():
    %4 : i16 = mem.symbol @False_String
    call.func @WriteLineString, %4
    core.return
}

