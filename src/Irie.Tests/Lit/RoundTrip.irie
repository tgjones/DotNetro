; RUN: @irie-as @file | @irie-dis

; CHECK: func @TestFunction : \(i32, i32\) -> i32 \{
func @TestFunction : (i32, i32) -> i32 {
; CHECK: bb0\(%0 : i32, %1 : i32\):
bb0(%0 : i32, %1 : i32):
  ; CHECK: %2 : i32 = arith.addi %0, %1
  %2 : i32 = arith.addi %0, %1
  ; CHECK: core.return %2
  core.return %2
}
