; RUN: @irie-as @file | @irie-dis

; Round-trip (text -> binary -> text) for arith.select, added for compare-
; narrowing phase 3. The writer/parser are generic, so this confirms the new
; opcode registers and encodes without bespoke handling.

; CHECK: func @TestSelect : (i8, i8, i1) -> i8 {
func @TestSelect : (i8, i8, i1) -> i8 {
; CHECK: bb0(%0 : i8, %1 : i8, %2 : i1):
bb0(%0 : i8, %1 : i8, %2 : i1):
  ; CHECK:     %3 : i8 = arith.select %2, %0, %1
  %3 : i8 = arith.select %2, %0, %1
  ; CHECK:     core.return %3
  core.return %3
}
