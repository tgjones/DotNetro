; RUN: @iriec --target mos6502-bbcmicro --emit=asm @file

; End-to-end check exercising frame slots: a struct-style value type lives
; in a frame slot, gets initialised to zero via mem.fill, then a single
; byte is stored to it and read back. Mirrors the shape of `UseStruct` in
; the DotNetCompilerTests suite — minus the call to Console.WriteLine.
;
; @TestStruct is a non-reentrant leaf (ReentrancyAnalysis) whose 4-byte i32
; frame fits the BBC Micro subtarget's 32-byte zero-page window ($70..$8F,
; FreeZeroPage). StaticFramePlacementPass (running before FrameLowering)
; therefore promotes the slot to ZeroPage at $70..$73, and every access lowers
; directly to a zero-page STA/LDA — no indirect-Y pointer-pair setup, and
; (the whole point of this rework) no PHA/PLA at all. Frame storage now lives in
; a dedicated zero-page window disjoint from the RC callee-saved register pool,
; so the prologue/epilogue pass never sees it as a register to preserve.

; CHECK: TestStruct:
; CHECK:     LDX #\$00
; CHECK:     TXA
; CHECK:     STA \$70
; CHECK:     TXA
; CHECK:     STA \$71
; CHECK:     TXA
; CHECK:     STA \$72
; CHECK:     TXA
; CHECK:     STA \$73
; CHECK:     TXA
; CHECK:     STA \$70
; CHECK:     RTS

func @TestStruct : () -> void {
  frame_slot 0 : i32 @UseStruct_local0

  bb0():
    %0 : i16 = mem.frame_addr 0
    %1 : i8  = arith.constant 0
    mem.fill %0, %1, 4
    mem.store.i8 %0, %1
    core.return
}
