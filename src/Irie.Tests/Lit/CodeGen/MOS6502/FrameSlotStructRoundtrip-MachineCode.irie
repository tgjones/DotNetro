; RUN: @iriec --target mos6502-bbcmicro --emit=asm @file

; End-to-end check exercising frame slots: a struct-style value type lives
; in a frame slot, gets initialised to zero via mem.fill, then a single
; byte is stored to it and read back. Mirrors the shape of `UseStruct` in
; the DotNetCompilerTests suite — minus the call to Console.WriteLine.
;
; The i32 slot belongs to a non-reentrant leaf, so MOS6502FramePlacementPass
; promotes it to the BBC Micro zero-page window at $70. Every byte access — the
; four mem.fill bytes at offsets 0..3 plus the explicit store at offset 0 —
; lowers, post-RA via FrameAccessLoweringPass, to a direct STA $70.. (the slot
; base $70 plus the byte offset). The zero byte is parked through $02 and loaded
; into $a (`LDA $02`) before each store — the store value now lives in $a, so
; there is no TXA and no pointer setup.

; CHECK: TestStruct:
; CHECK:     LDA #$00
; CHECK:     STA $02
; CHECK:     LDA $02
; CHECK:     STA $70
; CHECK:     LDA $02
; CHECK:     STA $71
; CHECK:     LDA $02
; CHECK:     STA $72
; CHECK:     LDA $02
; CHECK:     STA $73
; CHECK:     LDA $02
; CHECK:     STA $70
; CHECK:     RTS

func @TestStruct : () -> void {
  frame_slot 0 : i32 @UseStruct_local0

  bb0():
    %0 : i16 = mem.frame_addr 0
    %1 : i8  = arith.constant 0
    mem.fill %0, %1, 4
    mem.store.i8 %0, %1
    core.return
}
