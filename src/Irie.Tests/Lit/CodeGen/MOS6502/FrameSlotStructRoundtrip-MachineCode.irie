; RUN: @iriec --target mos6502-bbcmicro --emit=asm @file

; End-to-end check exercising frame slots: a struct-style value type lives
; in a frame slot, gets initialised to zero via mem.fill, then a single
; byte is stored to it and read back. Mirrors the shape of `UseStruct` in
; the DotNetCompilerTests suite — minus the call to Console.WriteLine.
;
; Stage 2 of the frame-placement rework: the i32 slot stays in absolute memory
; (no zero-page promotion yet), so every byte access — the four mem.fill bytes
; at offsets 0..3 plus the explicit store at offset 0 — lowers, post-RA via
; FrameAccessLoweringPass, to the absolute global + indirect-Y sequence
; (re-materialise the slot address into the $00/$01 pointer pair, set $y to the
; offset, STA ($00),Y). The zero byte is held in $x (parked through $02) and
; moved into $a with TXA before each store. Stage 3 promotes the slot to the
; BBC Micro zero-page window and these become direct STA $70.. .

; CHECK: TestStruct:
; CHECK:     LDA #\$00
; CHECK:     STA \$02
; CHECK:     LDX \$02
; CHECK:     LDA #<UseStruct_local0
; CHECK:     STA \$00
; CHECK:     LDA #>UseStruct_local0
; CHECK:     STA \$01
; CHECK:     LDY #\$00
; CHECK:     TXA
; CHECK:     STA \(\$00\),Y
; CHECK:     LDX \$02
; CHECK:     LDY #\$01
; CHECK:     TXA
; CHECK:     STA \(\$00\),Y
; CHECK:     LDX \$02
; CHECK:     LDY #\$02
; CHECK:     TXA
; CHECK:     STA \(\$00\),Y
; CHECK:     LDX \$02
; CHECK:     LDY #\$03
; CHECK:     TXA
; CHECK:     STA \(\$00\),Y
; CHECK:     LDX \$02
; CHECK:     LDY #\$00
; CHECK:     TXA
; CHECK:     STA \(\$00\),Y
; CHECK:     RTS

func @TestStruct : () -> void {
  frame_slot 0 : i32 @UseStruct_local0

  bb0():
    %0 : i16 = mem.frame_addr 0
    %1 : i8  = arith.constant 0
    mem.fill %0, %1, 4
    mem.store.i8 %0, %1
    core.return
}
