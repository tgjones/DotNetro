; RUN: @iriec --target mos6502 --stop-after CopyElimination @file

; Checks the unified-MIR pipeline output after CopyElimination — the final
; pass in the v2 pipeline today. All identity pseudo.copy instructions left
; by the register allocator (e.g. $a = pseudo.copy $a) are removed, leaving
; only substantive copies, the four chained adcs, the leading clc, and the
; closing rts.

; CHECK: func @TestFunction : \(i32, i32\) -> i32 \{
; CHECK:   bb0\(\):
; CHECK:     \[liveins: \$a, \$x, \$zp2, \$zp3, \$zp4, \$zp5, \$zp6, \$zp7\]
; CHECK:     \$c = mos6502.clc
; CHECK:     \$a, \$c = mos6502.adc \$a, \$zp4, \$c
; CHECK:     \$zp4 = pseudo.copy \$a
; CHECK:     \$a = pseudo.copy \$x
; CHECK:     \$a, \$c = mos6502.adc \$a, \$zp5, \$c
; CHECK:     \$zp5 = pseudo.copy \$a
; CHECK:     \$a = pseudo.copy \$zp2
; CHECK:     \$zp2 = pseudo.copy \$zp6
; CHECK:     \$a, \$c = mos6502.adc \$a, \$zp2, \$c
; CHECK:     \$zp2 = pseudo.copy \$a
; CHECK:     \$a = pseudo.copy \$zp3
; CHECK:     \$zp3 = pseudo.copy \$zp7
; CHECK:     \$a, \$c = mos6502.adc \$a, \$zp3, \$c
; CHECK:     \$zp3 = pseudo.copy \$a
; CHECK:     \$a = pseudo.copy \$zp4
; CHECK:     \$x = pseudo.copy \$zp5
; CHECK:     mos6502.rts implicit \$a, implicit \$x, implicit \$zp2, implicit \$zp3
; CHECK: \}

func @TestFunction : (i32, i32) -> i32 {
bb0(%0 : i32, %1 : i32):
    %2 : i32 = arith.addi %0, %1
    core.return %2
}
