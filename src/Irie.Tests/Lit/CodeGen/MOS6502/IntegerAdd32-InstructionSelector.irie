; RUN: @iriec --target mos6502 --stop-after InstructionSelector @file

; Checks the unified-MIR instruction selector. The post-legalizer MIR is:
;   - `arith.constant 0 : i1` (the chain-head carry-in materialized by the
;     legalizer)
;   - four `arith.addi_with_carry %a, %b, %carry_in` ops in a chain
;
; The selector lowers them to:
;   - `mos6502.clc`            (def: class cc vreg — replaces the i1 constant)
;   - `mos6502.adc` (pre-AMS)  with class ac / cc defs and class ac / zp /
;     cc uses. use[0] is tied to def[0]; the dialect's GetInstructionInfo
;     supplies the tied-def metadata so the writer prints `(tied-def 0)`.
;
; Each `mos6502.adc` exposes both result (i8, class ac) and carry_out
; (i1, class cc) as SSA defs, taking the previous carry_out as an explicit
; vreg use so the carry chain is visible in the IR.
;
; Vreg classes after isel:
;   - LHS bytes (operand a): class ac (back-propagated from adc's L use,
;     even when sourced from a non-ac phys reg).
;   - RHS bytes (operand b): class zp.
;   - Carry vregs:           class cc.
;
; The `pseudo.return` is lowered to `mos6502.rts` with implicit-uses of every
; physreg defined by a preceding `pseudo.copy` in the same block (i.e. the
; return physregs ABI lowering populated).
;
; Physreg names are still uppercase here — the lowercase rename is deferred to
; step 17 of notes/unified-ir-plan.md. The v2 engine lit tests use the `-v2`
; suffix until the old engine is retired.

; CHECK: func @TestFunction : (i32, i32) -> i32 {
; CHECK: bb0():
; CHECK:     [liveins: $a, $x, $zp2, $zp3, $zp4, $zp5, $zp6, $zp7]
; CHECK:     %3 : ac = pseudo.copy $a
; CHECK:     %4 : ac = pseudo.copy $x
; CHECK:     %5 : ac = pseudo.copy $zp2
; CHECK:     %6 : ac = pseudo.copy $zp3
; CHECK:     %7 : zp = pseudo.copy $zp4
; CHECK:     %8 : zp = pseudo.copy $zp5
; CHECK:     %9 : zp = pseudo.copy $zp6
; CHECK:     %10 : zp = pseudo.copy $zp7
; CHECK:     %32 : cc = mos6502.clc
; CHECK:     %33 : ac, %34 : cc = mos6502.adc %3(tied-def 0), %7, %32
; CHECK:     %35 : ac, %36 : cc = mos6502.adc %4(tied-def 0), %8, %34
; CHECK:     %37 : ac, %38 : cc = mos6502.adc %5(tied-def 0), %9, %36
; CHECK:     %39 : ac, %40 : cc = mos6502.adc %6(tied-def 0), %10, %38
; CHECK:     $a = pseudo.copy %33
; CHECK:     $x = pseudo.copy %35
; CHECK:     $zp2 = pseudo.copy %37
; CHECK:     $zp3 = pseudo.copy %39
; CHECK:     mos6502.rts implicit $a, implicit $x, implicit $zp2, implicit $zp3
; CHECK: }

func @TestFunction : (i32, i32) -> i32 {
bb0(%0 : i32, %1 : i32):
    %2 : i32 = arith.addi %0, %1
    core.return %2
}
