; RUN: @iriec --target mos6502 --emit=asm @file

; @Inc loops `i = i + 1` until `i >= limit`, with the loop-carried counter %2 a
; block parameter (one physreg held across the back-edge). The counter is BOTH
; incremented AND compared each iteration.
;
; The increment strength-reduction pass (plan Item 1) rewrites an in-place
; `value + 1` to a single INX / INY / INC when the allocator has parked the
; value in X / Y / zero page. It does NOT fire here, and that is correct: our
; `cmp` lowering only emits CMP (which compares $a) — it has no CPX / CPY — so a
; counter kept in Y would have to be copied to $a (TYA) before each compare
; anyway. Pinning the counter to $a and incrementing with CLC / ADC #1 is then
; strictly smaller than the folded `Y + INY + TYA` form — it drops the entry
; copy-to-Y, the per-iteration copy-to-$a, and the epilogue copy-to-$a
; (8 instructions here vs. 11 for the folded form).
;
; This became reachable once the cmp lowering stopped funnelling its $a operand
; through a defensive copy (the constrainSelectedInstRegOperands port): the
; counter's compare-use now narrows it to $a directly, so the allocator keeps it
; there for the whole loop instead of in Y. Folding the increment AND keeping the
; counter in Y would need a CPX / CPY-based compare lowering — future work.

; CHECK: Inc:
; CHECK:     STX $02
; CHECK: .bb1:
; CHECK:     CLC
; CHECK:     ADC #$01
; CHECK:     CMP $02
; CHECK:     BCS .bb2
; CHECK:     JMP .bb1
; CHECK: .bb2:
; CHECK:     RTS

func @Inc : (i8, i8) -> i8 {
bb0(%0 : i8, %1 : i8):
    cf.br bb1(%0)
bb1(%2 : i8):
    %3 : i8 = arith.constant 1
    %4 : i1 = arith.constant 0
    %5 : i8, %6 : i1 = arith.addi_with_carry %2, %3, %4
    %7 : i1 = arith.cmpi ult, %5, %1
    cf.cond_br %7, bb1(%5), bb2(%5)
bb2(%8 : i8):
    core.return %8
}
