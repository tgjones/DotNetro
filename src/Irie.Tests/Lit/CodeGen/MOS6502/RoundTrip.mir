; RUN: @irie-cg @file

; Simple function: two parameters, one block, binary op and return.

; CHECK: func @add : \(i16, i16\) -> i16 \{
func @add : (i16, i16) -> i16 {
; CHECK:   bb0\(%0:i16, %1:i16\):
  bb0(%0:i16, %1:i16):
; CHECK:     %2:i16 = GenericAdd %0, %1
    %2:i16 = GenericAdd %0, %1
; CHECK:     GenericReturn %2
    GenericReturn %2
}

; Function with branches — bb1 and bb2 are forward references from bb0,
; which exercises the two-pass block-registration in the parser.

; CHECK: func @select : \(i16, i16, i16\) -> i16 \{
func @select : (i16, i16, i16) -> i16 {
; CHECK:   bb0\(%0:i16, %1:i16, %2:i16\):
  bb0(%0:i16, %1:i16, %2:i16):
; CHECK:     GenericBranchConditional %0, bb1, bb2
    GenericBranchConditional %0, bb1, bb2
; CHECK:   bb1\(\):
  bb1():
; CHECK:     GenericReturn %1
    GenericReturn %1
; CHECK:   bb2\(\):
  bb2():
; CHECK:     GenericReturn %2
    GenericReturn %2
}
