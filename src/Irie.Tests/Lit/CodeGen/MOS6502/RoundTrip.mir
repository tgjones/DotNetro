; RUN: @iriec --run-pass=none @file

; Simple function: two parameters, one block, binary op, copy result back to a physreg.

; CHECK: func @add \{
func @add {
; CHECK:   bb0\(\):
  bb0():
; CHECK:     liveins: \$A, \$X
    liveins: $A, $X
; CHECK:     %0:i16 = GenericCopy \$A
    %0:i16 = GenericCopy $A
; CHECK:     %1:i16 = GenericCopy \$X
    %1:i16 = GenericCopy $X
; CHECK:     %2:i16 = GenericAdd %0, %1
    %2:i16 = GenericAdd %0, %1
; CHECK:     \$A = GenericCopy %2
    $A = GenericCopy %2
}

; Function with branches — bb1 and bb2 are forward references from bb0,
; which exercises the two-pass block-registration in the parser.

; CHECK: func @select \{
func @select {
; CHECK:   bb0\(\):
  bb0():
; CHECK:     liveins: \$A, \$X, \$Y
    liveins: $A, $X, $Y
; CHECK:     %0:i16 = GenericCopy \$A
    %0:i16 = GenericCopy $A
; CHECK:     %1:i16 = GenericCopy \$X
    %1:i16 = GenericCopy $X
; CHECK:     %2:i16 = GenericCopy \$Y
    %2:i16 = GenericCopy $Y
; CHECK:     GenericBranchConditional %0, bb1, bb2
    GenericBranchConditional %0, bb1, bb2
; CHECK:   bb1\(\):
  bb1():
; CHECK:     \$A = GenericCopy %1
    $A = GenericCopy %1
; CHECK:   bb2\(\):
  bb2():
; CHECK:     \$A = GenericCopy %2
    $A = GenericCopy %2
}
