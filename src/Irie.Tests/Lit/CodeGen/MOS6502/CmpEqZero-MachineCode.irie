; RUN: @iriec --target mos6502 --emit=asm @file

; Step 16 (plan §6 G5): brfalse lowers to `arith.cmpi <eq>, %x, <0>` + cf.cond_br.
; Verify the eq-against-constant-0 path end-to-end at i8, i16, and i32. The
; constant 0 operand is folded directly into an immediate compare
; (`CMP #$00`) — one per operand byte — by MOS6502InstructionSelector, so no
; zero is ever materialized into zero page. The cmpi+cond_br fusion then emits
; the per-byte CMP / BEQ / BNE chain. Where a byte is produced by a flag-setting
; load/transfer (TXA / TYA / LDA from a parameter byte), MOS6502LateOptimization
; drops the redundant `CMP #$00` — the load/transfer already set N/Z — so only
; the i8 case (value arriving in $a as a bare live-in, no producer) keeps an
; explicit compare. This is the regression guard for the frontend's `brfalse`.
;
; The compared value arrives in $a/$x (call-convention live-ins) and is compared
; against the immediate directly, so the live parameter byte stays in $a and the
; CMP reads it without any scratch GPR or eviction.

; --- i8: single immediate CMP of $a vs 0. Both exits return void, so
; ReturnMergePass funnels them into one block and MOS6502TailDuplication leaves a
; single shared RTS that both BEQ edges reach. ---

; CHECK: CmpEqZeroI8:
; CHECK:     CMP \#\$00
; CHECK:     BEQ \.bb1
; CHECK: \.bb1:
; CHECK:     RTS
; CHECK: CmpEqZeroI16:
; CHECK:     TAY
; CHECK:     TXA
; CHECK:     BNE \.bb1
; CHECK:     TYA
; CHECK:     BNE \.bb1
; CHECK: \.bb1:
; CHECK:     RTS
; CHECK: CmpEqZeroI32:
; CHECK:     TAY
; CHECK:     LDA \$03
; CHECK:     BNE \.bb1
; CHECK:     LDA \$02
; CHECK:     BNE \.bb1
; CHECK:     TXA
; CHECK:     BNE \.bb1
; CHECK:     TYA
; CHECK:     BNE \.bb1
; CHECK: \.bb1:
; CHECK:     RTS

func @CmpEqZeroI8 : (i8) -> void {
bb0(%0 : i8):
    %1 : i8 = arith.constant 0
    %2 : i1 = arith.cmpi eq, %0, %1
    cf.cond_br %2, bb1, bb2
bb1():
    core.return
bb2():
    core.return
}

func @CmpEqZeroI16 : (i16) -> void {
bb0(%0 : i16):
    %1 : i16 = arith.constant 0
    %2 : i1 = arith.cmpi eq, %0, %1
    cf.cond_br %2, bb1, bb2
bb1():
    core.return
bb2():
    core.return
}

func @CmpEqZeroI32 : (i32) -> void {
bb0(%0 : i32):
    %1 : i32 = arith.constant 0
    %2 : i1 = arith.cmpi eq, %0, %1
    cf.cond_br %2, bb1, bb2
bb1():
    core.return
bb2():
    core.return
}
