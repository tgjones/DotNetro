; RUN: @iriec --target mos6502 --emit=asm @file

; Signed i8 arith.cmpi (slt) against a non-zero operand, fused with cf.cond_br.
; This is the i8 counterpart of CmpSignedI16/I32Branch: a general signed compare
; (not the against-zero sign test) biases both operands by EOR #$80 so the
; unsigned CMP + BCC computes the signed less-than. `a <s b` ⟺ (a^$80) <u (b^$80).
;
; The two bytes arrive in $a (%0) and $x (%1); each is funneled through $a to be
; EOR'd, the biased %1 is parked in zero page, and the biased %0 is compared
; against it. BCC takes the true edge (a < b, returns 1); the false edge (returns
; 0) falls through. The two i8 returns are funnelled into one block by
; ReturnMergePass, so the shared RTS is reached by fall-through from the false
; tail and inlined into the true tail by MOS6502TailDuplication.

; CHECK: TestSltI8:
; CHECK:     EOR #$80
; CHECK:     TAY
; CHECK:     TXA
; CHECK:     EOR #$80
; CHECK:     STA $02
; CHECK:     TYA
; CHECK:     CMP $02
; CHECK:     BCC .bb3
; CHECK: .bb1:
; CHECK:     LDA #$00
; CHECK: .bb2:
; CHECK:     RTS
; CHECK: .bb3:
; CHECK:     LDA #$01
; CHECK:     RTS

func @TestSltI8 : (i8, i8) -> i8 {
bb0(%0 : i8, %1 : i8):
    %2 : i1 = arith.cmpi slt, %0, %1
    cf.cond_br %2, bb1(), bb2()
bb1():
    %3 : i8 = arith.constant 1
    core.return %3
bb2():
    %4 : i8 = arith.constant 0
    core.return %4
}
