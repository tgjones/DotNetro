; RUN: @iriec --target mos6502 --emit=asm @file

; End-to-end check for mem.load.i16 / mem.store.i16 through a mem.symbol
; address. The Custom legalizer rewrites each wide op into a chain of
; per-byte mem.load.byte_at / mem.store.byte_at calls at offsets 0..1. Because
; the address resolves to a static symbol, isel selects absolute addressing
; (lda.abs / sta.abs @ptr and @ptr+1) — no zero-page pointer pair, no LDY.

; CHECK: TestMemI16:
; CHECK:     LDA ptr
; CHECK:     TAX
; CHECK:     LDA ptr\+1
; CHECK:     STX ptr
; CHECK:     STA ptr\+1
; CHECK:     RTS

global @ptr : i32

func @TestMemI16 : () -> void {
bb0():
    %0 : i16 = mem.symbol @ptr
    %1 : i16 = mem.load.i16 %0
    mem.store.i16 %0, %1
    core.return
}
