; RUN: @iriec --target mos6502-bbcmicro --emit=asm @file

; Static frame placement across a two-deep call chain.
;
; All three functions are non-reentrant (ReentrancyAnalysis), so the
; target-private MOS6502FramePlacementPass — running post-RA, before the generic
; FrameAccessLoweringPass — colours their frame slots into the BBC Micro
; subtarget's zero-page window ($70..$8F) with a bottom-up static-stack layout:
;
;   base(f) = max over callees c of (base(c) + size(c))
;
; @leaf_a and @leaf_b are independent leaves (base 0): they REUSE the same zero
; page — both colour their slot at $70. @mid CALLS @leaf_a, so its frame base is
; leaf_a's frame end (2 bytes) → its slot lands at $72, DISJOINT from the
; callee's $70. That disjointness is what lets the value @mid stores into its
; slot survive the `JSR leaf_a` and be read back unchanged afterwards.
;
; Every access is a direct zero-page LDA/STA (no indirect-Y pointer setup) and
; there is no PHA/PLA at all — frame storage lives in a dedicated zero-page
; window disjoint from the RC pool, and the colouring guarantees a callee never
; clobbers the caller's frame. The store value lives in $a (no TXA).

; --- leaf_a: slot at $70 (base 0) ---------------------------------------
; CHECK: leaf_a:
; CHECK:     LDA #\$07
; CHECK:     STA \$70
; CHECK:     RTS

; --- leaf_b: independent leaf — REUSES $70 (base 0) ----------------------
; CHECK: leaf_b:
; CHECK:     LDA #\$09
; CHECK:     STA \$70
; CHECK:     RTS

; --- mid: calls leaf_a — frame DISJOINT from callee, slot at $72 ---------
; CHECK: mid:
; CHECK:     LDA #\$03
; CHECK:     STA \$72
; CHECK:     JSR leaf_a
; CHECK:     LDA \$72
; CHECK:     STA \$72
; CHECK:     RTS

func @leaf_a : () -> void {
  frame_slot 0 : i16 @leaf_a_local0
  bb0():
    %0 : i16 = mem.frame_addr 0
    %1 : i8 = arith.constant 7
    mem.store.i8 %0, %1
    core.return
}

func @leaf_b : () -> void {
  frame_slot 0 : i16 @leaf_b_local0
  bb0():
    %0 : i16 = mem.frame_addr 0
    %1 : i8 = arith.constant 9
    mem.store.i8 %0, %1
    core.return
}

func @mid : () -> void {
  frame_slot 0 : i16 @mid_local0
  bb0():
    %0 : i16 = mem.frame_addr 0
    %1 : i8 = arith.constant 3
    mem.store.i8 %0, %1
    call.func @leaf_a
    %2 : i8 = mem.load.i8 %0
    mem.store.i8 %0, %2
    core.return
}
