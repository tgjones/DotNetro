; RUN: @iriec --target mos6502-bbcmicro --emit=asm @file

; Static frame accesses across a two-deep call chain.
;
; STAGE 2 of the frame-placement rework: every frame slot is placed in absolute
; memory (StackId == default) and each byte access lowers — late, post-RA, via
; FrameAccessLoweringPass → MOS6502FrameLowering.LowerFrameAccess — to the
; absolute global + indirect-Y sequence (materialise the slot address into the
; $00/$01 pointer pair, set $y to the byte offset, then LDA/STA ($00),Y). No
; slot is promoted to zero page yet; that is Stage 3, which adds a target-private
; post-RA placement pass and the direct-zp branch in LowerFrameAccess, at which
; point these CHECK lines return to direct LDA/STA $70.. (commit b24e2ff's
; output). For now this just pins down the indirect-Y reversion.

; --- leaf_a -------------------------------------------------------------
; CHECK: leaf_a:
; CHECK:     LDX #\$07
; CHECK:     LDA #<leaf_a_local0
; CHECK:     STA \$00
; CHECK:     LDA #>leaf_a_local0
; CHECK:     STA \$01
; CHECK:     LDY #\$00
; CHECK:     TXA
; CHECK:     STA \(\$00\),Y
; CHECK:     RTS

; --- leaf_b -------------------------------------------------------------
; CHECK: leaf_b:
; CHECK:     LDX #\$09
; CHECK:     LDA #<leaf_b_local0
; CHECK:     STA \$00
; CHECK:     LDA #>leaf_b_local0
; CHECK:     STA \$01
; CHECK:     LDY #\$00
; CHECK:     TXA
; CHECK:     STA \(\$00\),Y
; CHECK:     RTS

; --- mid: stores, calls leaf_a, reads its slot back, stores again ------
; CHECK: mid:
; CHECK:     LDX #\$03
; CHECK:     LDA #<mid_local0
; CHECK:     STA \$00
; CHECK:     LDA #>mid_local0
; CHECK:     STA \$01
; CHECK:     LDY #\$00
; CHECK:     TXA
; CHECK:     STA \(\$00\),Y
; CHECK:     JSR leaf_a
; CHECK:     LDA #<mid_local0
; CHECK:     STA \$00
; CHECK:     LDA #>mid_local0
; CHECK:     STA \$01
; CHECK:     LDY #\$00
; CHECK:     LDA \(\$00\),Y
; CHECK:     TAX
; CHECK:     LDA #<mid_local0
; CHECK:     STA \$00
; CHECK:     LDA #>mid_local0
; CHECK:     STA \$01
; CHECK:     LDY #\$00
; CHECK:     TXA
; CHECK:     STA \(\$00\),Y
; CHECK:     RTS

func @leaf_a : () -> void {
  frame_slot 0 : i16 @leaf_a_local0
  bb0():
    %0 : i16 = mem.frame_addr 0
    %1 : i8 = arith.constant 7
    mem.store.i8 %0, %1
    core.return
}

func @leaf_b : () -> void {
  frame_slot 0 : i16 @leaf_b_local0
  bb0():
    %0 : i16 = mem.frame_addr 0
    %1 : i8 = arith.constant 9
    mem.store.i8 %0, %1
    core.return
}

func @mid : () -> void {
  frame_slot 0 : i16 @mid_local0
  bb0():
    %0 : i16 = mem.frame_addr 0
    %1 : i8 = arith.constant 3
    mem.store.i8 %0, %1
    call.func @leaf_a
    %2 : i8 = mem.load.i8 %0
    mem.store.i8 %0, %2
    core.return
}
