; RUN: @iriec --target mos6502 --stop-after MOS6502AddressingModeSelector @file

; Checks the unified-MIR pipeline output after the target-private
; MOS6502AddressingModeSelector pass — the first post-RA target pass added
; by MOS6502TargetV2.AddPostRegisterAllocationPasses. The adcs already carry
; their concrete addressing-mode form (`mos6502.adc.zp`, selected directly by
; isel — there is no pre-AMS `mos6502.adc`), so AMS leaves the whole chain
; untouched here. The pass still refines other families (cmp, the StAbs store);
; this test pins that the add chain passes through unchanged.

; CHECK: func @TestFunction : (i32, i32) -> i32 {
; CHECK: bb0():
; CHECK:     [liveins: $a, $x, $zp2, $zp3, $zp4, $zp5, $zp6, $zp7]
; CHECK:     $c = mos6502.clc
; CHECK:     $a, $c = mos6502.adc.zp $a, $zp4, $c
; CHECK:     $y = pseudo.copy $a
; CHECK:     $a = pseudo.copy $x
; CHECK:     $a, $c = mos6502.adc.zp $a, $zp5, $c
; CHECK:     $x = pseudo.copy $a
; CHECK:     $a = pseudo.copy $zp2
; CHECK:     $a, $c = mos6502.adc.zp $a, $zp6, $c
; CHECK:     $zp2 = pseudo.copy $a
; CHECK:     $a = pseudo.copy $zp3
; CHECK:     $a, $c = mos6502.adc.zp $a, $zp7, $c
; CHECK:     $zp3 = pseudo.copy $a
; CHECK:     $a = pseudo.copy $y
; CHECK:     mos6502.rts implicit $a, implicit $x, implicit $zp2, implicit $zp3
; CHECK: }

func @TestFunction : (i32, i32) -> i32 {
bb0(%0 : i32, %1 : i32):
    %2 : i32 = arith.addi %0, %1
    core.return %2
}
