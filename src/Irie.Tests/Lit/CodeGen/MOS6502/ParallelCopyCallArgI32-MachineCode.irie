; RUN: @iriec --target mos6502 --emit=asm @file

; Exercises MOS6502ParallelCopyPass on a multi-byte call-argument shuffle.
;
; CC_MOS passes a 32-bit value LSB-first in $a, $x, $zp2($02), $zp3($03). RA
; parks the four constant bytes of 0x12345678 in $02..$05, then the call lowering
; emits the acyclic parallel copy {A<-$02, X<-$03, $02<-$04, $03<-$05}. On the
; 6502 the two zp→zp moves expand to LDA;STA and clobber $a, so naïvely loading
; $a first would lose the argument. The pass instead:
;   * evacuates byte 0 out of $02 into a free scratch slot ($06) before $02 is
;     overwritten, and
;   * emits the $a-destined load LAST,
; so byte 0 (0x78) reaches $a intact at the JSR.

; CHECK: CallI32:
; CHECK:     LDA #\$78
; CHECK:     STA \$02
; CHECK:     LDA #\$56
; CHECK:     STA \$03
; CHECK:     LDA #\$34
; CHECK:     STA \$04
; CHECK:     LDA #\$12
; CHECK:     STA \$05
; The $02-home byte 0 is evacuated to scratch before $02 is reused ...
; CHECK:     LDA \$02
; CHECK:     STA \$06
; CHECK:     LDX \$03
; CHECK:     LDA \$04
; CHECK:     STA \$02
; CHECK:     LDA \$05
; CHECK:     STA \$03
; ... and byte 0 is loaded into $a LAST, just before the call.
; CHECK:     LDA \$06
; CHECK:     JSR SinkI32

func @SinkI32 : (i32) -> void {
bb0(%0 : i32):
    core.return
}

func @CallI32 : () -> void {
bb0():
    %0 : i32 = arith.constant 305419896
    call.func @SinkI32, %0
    core.return
}
