; RUN: @iriec --target mos6502 --emit=asm @file

; Motivating consumer for `arith.select` (compare-narrowing phase 3, step 1).
; A *materialized* (non-fused) select: the cmpi feeds a select whose result is
; returned, so the select must lower to a value-producing diamond rather than a
; branch to distinct blocks. This is the acceptance criterion for the
; MirSelectLoweringPass materialized path.
;
; The frontend lowers source-level `?:` to a CFG diamond directly, so the only
; way to exercise a true `arith.select` is hand-authored MIR (here).
;
; MirSelectLoweringPass turns each `arith.select` into a cf.cond_br diamond whose
; condition is the cmpi; the existing cmpi+cond_br fusion then lowers the compare
; with no new isel code, and the arms merge the chosen value via a block-arg phi.

; --- min(a, b) = a <s b ? a : b -----------------------------------------------
; CHECK: select_min8:
; CHECK:     TAY
; CHECK:     STX \$03
; CHECK:     EOR \#\$80
; CHECK:     TAX
; CHECK:     LDA \$03
; CHECK:     EOR \#\$80
; CHECK:     STA \$02
; CHECK:     TXA
; CHECK:     CMP \$02
; CHECK:     BCC \.bb2
; CHECK: \.bb1:
; CHECK:     LDY \$03
; CHECK: \.bb2:
; CHECK:     TYA
; CHECK:     RTS
func @select_min8 : (i8, i8) -> i8 {
bb0(%0 : i8, %1 : i8):
    %2 : i1 = arith.cmpi slt, %0, %1
    %3 : i8 = arith.select %2, %0, %1
    core.return %3
}

; --- max(a, b) = a <s b ? b : a (arms swapped) --------------------------------
; CHECK: select_max8:
; CHECK:     STA \$03
; CHECK:     STX \$02
; CHECK:     LDY \$02
; CHECK:     EOR \#\$80
; CHECK:     TAX
; CHECK:     TYA
; CHECK:     EOR \#\$80
; CHECK:     STA \$02
; CHECK:     TXA
; CHECK:     CMP \$02
; CHECK:     BCC \.bb2
; CHECK: \.bb1:
; CHECK:     LDY \$03
; CHECK: \.bb2:
; CHECK:     TYA
; CHECK:     RTS
func @select_max8 : (i8, i8) -> i8 {
bb0(%0 : i8, %1 : i8):
    %2 : i1 = arith.cmpi slt, %0, %1
    %3 : i8 = arith.select %2, %1, %0
    core.return %3
}

; --- abs(x) = x <s 0 ? -x : x — a select over two computed values. -----------
; The `-x` (subi 0, x) is single-use and feeds only the true arm, so arm-sinking
; moves it into bb1 (computed only on the negative path) — see the SBC in bb1.
; Sinking it out of the entry block also keeps the cmpi adjacent to the cond_br.
; Because the diamond is formed before the legalizer, the `x <s 0` compare is
; normalized to the optimal high-byte sign test (CMP #$00 + BMI), not an EOR bias.
; The CMP #$00 is then dropped by MOS6502LateOptimization (the preceding LDA $02
; already set N), leaving just LDA + BMI.
; CHECK: select_abs8:
; CHECK:     STA \$02
; CHECK:     LDX \#\$00
; CHECK:     LDA \$02
; CHECK:     BMI \.bb2
; CHECK: \.bb1:
; CHECK:     LDA \$02
; CHECK:     RTS
; CHECK: \.bb2:
; CHECK:     SEC
; CHECK:     TXA
; CHECK:     SBC \$02
; CHECK:     STA \$02
; CHECK:     JMP \.bb1
func @select_abs8 : (i8) -> i8 {
bb0(%0 : i8):
    %1 : i8 = arith.constant 0
    %2 : i1 = arith.cmpi slt, %0, %1
    %3 : i8 = arith.subi %1, %0
    %4 : i8 = arith.select %2, %3, %0
    core.return %4
}

; --- 16-bit min: exercises same-test merge (narrowed to 2 i8 selects sharing
; the condition → ONE diamond, both bytes set per arm) + wide cmpi. ------------
; CHECK: select_min16:
; CHECK:     STA \$05
; CHECK:     STX \$04
; CHECK:     LDY \$02
; CHECK:     STY \$07
; CHECK:     LDY \$03
; CHECK:     STY \$06
; CHECK:     LDY \$02
; CHECK:     STY \$08
; CHECK:     STA \$09
; CHECK:     TXA
; CHECK:     LDX \$03
; CHECK:     LDY \$09
; CHECK:     STY \$03
; CHECK:     EOR \#\$80
; CHECK:     TAY
; CHECK:     TXA
; CHECK:     EOR \#\$80
; CHECK:     STA \$02
; CHECK:     TYA
; CHECK:     CMP \$02
; CHECK:     BCC \.bb2
; CHECK:     BNE \.bb1
; CHECK:     LDA \$03
; CHECK:     CMP \$08
; CHECK:     BCC \.bb2
; CHECK: \.bb1:
; CHECK:     LDA \$07
; CHECK:     STA \$05
; CHECK:     LDA \$06
; CHECK:     STA \$04
; CHECK: \.bb2:
; CHECK:     LDA \$05
; CHECK:     LDX \$04
; CHECK:     RTS
func @select_min16 : (i16, i16) -> i16 {
bb0(%0 : i16, %1 : i16):
    %2 : i1 = arith.cmpi slt, %0, %1
    %3 : i16 = arith.select %2, %0, %1
    core.return %3
}
