; RUN: @iriec --target mos6502 --engine v2 --run-pass CopyElimination @file

; Only the identity copy ($A = pseudo.copy $A) is removed.
; The non-identity copy ($A = pseudo.copy $X) and the mos6502.adc instruction
; (a non-copy with two physical-register defs) are both left untouched.

; CHECK: func @mixed : \(\) -> void \{
; CHECK:   bb0\(\):
; CHECK:     \$A = pseudo.copy \$X
; CHECK:     \$A, \$C = mos6502.adc \$A, \$RC4, \$C
; CHECK: \}

func @mixed : () -> void {
bb0():
    $0 = pseudo.copy $0
    $0 = pseudo.copy $1
    $0, $5 = mos6502.adc $0, $10, $5
}
