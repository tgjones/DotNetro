; RUN: @iriec --target mos6502 --emit=asm @file

; Step 16 (plan §6 G5): brtrue lowers to `arith.cmpi <ne>, %x, <0>` + cf.cond_br.
; Verify the ne-against-constant-0 path end-to-end at i8, i16, and i32. Mirror
; of CmpEqZero-MachineCode.irie but with the true/false targets swapped: any
; BNE early-exits to the true block, and full equality falls through to false.
; This is the regression guard for the frontend's `brtrue`.
;
; As in CmpEqZero, the const-0 materialization's scratch GPR is chosen post-RA
; by RegisterScavengingPass (plan §3.6): the dead $x for i8, the dead $y for
; i16/i32. The live-in byte stays in $a (no eviction) and the CMP reads it
; directly. (The old RA $a-scratch reservation, now deleted, used to evict it.)

; --- i8: materialise 0 via dead $x, single CMP of $a vs 0, BNE true / JMP false. ---

; CHECK: CmpNeZeroI8:
; CHECK:     LDX #\$00
; CHECK:     STX \$02
; CHECK:     CMP \$02
; CHECK:     BNE \.bb1
; CHECK:     JMP \.bb2
; CHECK: \.bb1:
; CHECK:     RTS
; CHECK: \.bb2:
; CHECK:     RTS
; CHECK:
; CHECK: CmpNeZeroI16:
; CHECK:     LDY #\$00
; CHECK:     STY \$02
; CHECK:     LDY #\$00
; CHECK:     STY \$03
; CHECK:     STA \$06
; CHECK:     LDA \$06
; CHECK:     STA \$04
; CHECK:     STX \$05
; CHECK:     TXA
; CHECK:     CMP \$03
; CHECK:     BNE \.bb1
; CHECK:     LDA \$04
; CHECK:     CMP \$02
; CHECK:     BNE \.bb1
; CHECK:     JMP \.bb2
; CHECK: \.bb1:
; CHECK:     RTS
; CHECK: \.bb2:
; CHECK:     RTS
; CHECK:
; CHECK: CmpNeZeroI32:
; CHECK:     LDY #\$00
; CHECK:     STY \$04
; CHECK:     LDY #\$00
; CHECK:     STY \$05
; CHECK:     LDY #\$00
; CHECK:     STY \$06
; CHECK:     LDY #\$00
; CHECK:     STY \$07
; CHECK:     STA \$08
; CHECK:     STX \$09
; CHECK:     LDA \$03
; CHECK:     CMP \$07
; CHECK:     BNE \.bb1
; CHECK:     LDA \$02
; CHECK:     CMP \$06
; CHECK:     BNE \.bb1
; CHECK:     LDA \$09
; CHECK:     CMP \$05
; CHECK:     BNE \.bb1
; CHECK:     LDA \$08
; CHECK:     CMP \$04
; CHECK:     BNE \.bb1
; CHECK:     JMP \.bb2
; CHECK: \.bb1:
; CHECK:     RTS
; CHECK: \.bb2:
; CHECK:     RTS

func @CmpNeZeroI8 : (i8) -> void {
bb0(%0 : i8):
    %1 : i8 = arith.constant 0
    %2 : i1 = arith.cmpi ne, %0, %1
    cf.cond_br %2, bb1, bb2
bb1():
    core.return
bb2():
    core.return
}

func @CmpNeZeroI16 : (i16) -> void {
bb0(%0 : i16):
    %1 : i16 = arith.constant 0
    %2 : i1 = arith.cmpi ne, %0, %1
    cf.cond_br %2, bb1, bb2
bb1():
    core.return
bb2():
    core.return
}

func @CmpNeZeroI32 : (i32) -> void {
bb0(%0 : i32):
    %1 : i32 = arith.constant 0
    %2 : i1 = arith.cmpi ne, %0, %1
    cf.cond_br %2, bb1, bb2
bb1():
    core.return
bb2():
    core.return
}
