; RUN: @iriec --target mos6502 --emit=asm @file

; Step 16 (plan §6 G5): brtrue lowers to `arith.cmpi <ne>, %x, <0>` + cf.cond_br.
; Verify the ne-against-constant-0 path end-to-end at i8, i16, and i32. Mirror
; of CmpEqZero-MachineCode.irie but with the true/false targets swapped: any
; BNE early-exits to the true block, and full equality falls through to false.
; This is the regression guard for the frontend's `brtrue`.
;
; As in CmpEqZero, the live-in byte is stashed to a zero-page slot (STA $02 /
; STX $05) before the const-0 materialization clobbers $a, then reloaded for the
; CMP — RA now models the $a clobber of the LDA #$00 ; STA $zp const setup.

; --- i8: stash byte0, materialise 0, reload, single CMP, BNE true / JMP false. ---
; CHECK: CmpNeZeroI8:
; CHECK:     STA \$02
; CHECK:     LDA #\$00
; CHECK:     STA \$03
; CHECK:     LDA \$02
; CHECK:     CMP \$03
; CHECK:     BNE \.bb1
; CHECK:     JMP \.bb2

; --- i16: high byte first; any BNE exits to true; full equality → false. ---
; CHECK: CmpNeZeroI16:
; CHECK:     STA \$02
; CHECK:     LDA #\$00
; CHECK:     STA \$03
; CHECK:     LDA #\$00
; CHECK:     STA \$04
; CHECK:     STX \$05
; CHECK:     TXA
; CHECK:     CMP \$04
; CHECK:     BNE \.bb1
; CHECK:     LDA \$02
; CHECK:     CMP \$03
; CHECK:     BNE \.bb1
; CHECK:     JMP \.bb2

; --- i32: four-byte chain, same shape. ---
; CHECK: CmpNeZeroI32:
; CHECK:     STA \$04
; CHECK:     LDA #\$00
; CHECK:     STA \$05
; CHECK:     LDA #\$00
; CHECK:     STA \$06
; CHECK:     LDA #\$00
; CHECK:     STA \$07
; CHECK:     LDA #\$00
; CHECK:     STA \$08
; CHECK:     STX \$09
; CHECK:     LDA \$03
; CHECK:     CMP \$08
; CHECK:     BNE \.bb1
; CHECK:     LDA \$02
; CHECK:     CMP \$07
; CHECK:     BNE \.bb1
; CHECK:     LDA \$09
; CHECK:     CMP \$06
; CHECK:     BNE \.bb1
; CHECK:     LDA \$04
; CHECK:     CMP \$05
; CHECK:     BNE \.bb1
; CHECK:     JMP \.bb2

func @CmpNeZeroI8 : (i8) -> void {
bb0(%0 : i8):
    %1 : i8 = arith.constant 0
    %2 : i1 = arith.cmpi ne, %0, %1
    cf.cond_br %2, bb1, bb2
bb1():
    core.return
bb2():
    core.return
}

func @CmpNeZeroI16 : (i16) -> void {
bb0(%0 : i16):
    %1 : i16 = arith.constant 0
    %2 : i1 = arith.cmpi ne, %0, %1
    cf.cond_br %2, bb1, bb2
bb1():
    core.return
bb2():
    core.return
}

func @CmpNeZeroI32 : (i32) -> void {
bb0(%0 : i32):
    %1 : i32 = arith.constant 0
    %2 : i1 = arith.cmpi ne, %0, %1
    cf.cond_br %2, bb1, bb2
bb1():
    core.return
bb2():
    core.return
}
