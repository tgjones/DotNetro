; RUN: @iriec --target mos6502 --emit=asm @file

; Step 16 (plan §6 G5): brtrue lowers to `arith.cmpi <ne>, %x, <0>` + cf.cond_br.
; Verify the ne-against-constant-0 path end-to-end at i8, i16, and i32. This is
; the regression guard for the frontend's `brtrue`.
;
; The legalizer normalizes `ne` to `eq` with the branch's true/false edges
; swapped. For the multi-byte cases that reproduces the original BNE-to-true
; ladder exactly (the eq ladder's BNE-to-false becomes BNE-to-true once the
; edges are swapped); for the single-byte i8 case it emits BEQ-to-false +
; JMP-to-true.
;
; As in CmpEqZero, the const-0 materialization's scratch GPR is chosen post-RA
; by RegisterScavengingPass (plan §3.6): the dead $x for i8, the dead $y for
; i16/i32. The live-in byte stays in $a (no eviction) and the CMP reads it
; directly. (The old RA $a-scratch reservation, now deleted, used to evict it.)

; --- i8: materialise 0 via dead $x, single CMP of $a vs 0, BEQ false / JMP true. ---

; CHECK: CmpNeZeroI8:
; CHECK:     LDX #\$00
; CHECK:     STX \$02
; CHECK:     CMP \$02
; CHECK:     BEQ \.bb2
; CHECK:     JMP \.bb1
; CHECK: \.bb1:
; CHECK:     RTS
; CHECK: \.bb2:
; CHECK:     RTS
; CHECK: CmpNeZeroI16:
; CHECK:     LDY #\$00
; CHECK:     STY \$03
; CHECK:     LDY #\$00
; CHECK:     STY \$02
; CHECK:     TAY
; CHECK:     TXA
; CHECK:     CMP \$02
; CHECK:     BNE \.bb1
; CHECK:     TYA
; CHECK:     CMP \$03
; CHECK:     BNE \.bb1
; CHECK:     JMP \.bb2
; CHECK: \.bb1:
; CHECK:     RTS
; CHECK: \.bb2:
; CHECK:     RTS
; CHECK: CmpNeZeroI32:
; CHECK:     LDY #\$00
; CHECK:     STY \$07
; CHECK:     LDY #\$00
; CHECK:     STY \$06
; CHECK:     LDY #\$00
; CHECK:     STY \$05
; CHECK:     LDY #\$00
; CHECK:     STY \$04
; CHECK:     TAY
; CHECK:     LDA \$03
; CHECK:     CMP \$04
; CHECK:     BNE \.bb1
; CHECK:     LDA \$02
; CHECK:     CMP \$05
; CHECK:     BNE \.bb1
; CHECK:     TXA
; CHECK:     CMP \$06
; CHECK:     BNE \.bb1
; CHECK:     TYA
; CHECK:     CMP \$07
; CHECK:     BNE \.bb1
; CHECK:     JMP \.bb2
; CHECK: \.bb1:
; CHECK:     RTS
; CHECK: \.bb2:
; CHECK:     RTS

func @CmpNeZeroI8 : (i8) -> void {
bb0(%0 : i8):
    %1 : i8 = arith.constant 0
    %2 : i1 = arith.cmpi ne, %0, %1
    cf.cond_br %2, bb1, bb2
bb1():
    core.return
bb2():
    core.return
}

func @CmpNeZeroI16 : (i16) -> void {
bb0(%0 : i16):
    %1 : i16 = arith.constant 0
    %2 : i1 = arith.cmpi ne, %0, %1
    cf.cond_br %2, bb1, bb2
bb1():
    core.return
bb2():
    core.return
}

func @CmpNeZeroI32 : (i32) -> void {
bb0(%0 : i32):
    %1 : i32 = arith.constant 0
    %2 : i1 = arith.cmpi ne, %0, %1
    cf.cond_br %2, bb1, bb2
bb1():
    core.return
bb2():
    core.return
}
