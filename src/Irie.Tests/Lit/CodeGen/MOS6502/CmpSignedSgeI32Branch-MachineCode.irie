; RUN: @iriec --target mos6502 --emit=asm @file

; Step 9 (il-to-mir plan): signed i32 arith.cmpi (sge) fused with cf.cond_br.
; The legalizer normalizes `sge` to its inverse `slt` with the branch edges
; swapped, and the selector lowers `slt` via the unsigned `ult` ladder after the
; sign-bit flip (EOR #$80 on each operand's top byte). The ult ladder sends BCC
; to the (swapped) true target and BNE to the false target on the higher bytes,
; then ends with BCC on the last byte — identical to the old uge ladder on the
; higher bytes, with only the last-byte branch sense flipped.

; CHECK: TestSge32:
; CHECK:     EOR #\$80
; CHECK:     EOR #\$80
; CHECK:     CMP
; CHECK:     BCC \.bb2
; CHECK:     BNE \.bb1
; CHECK:     CMP
; CHECK:     BCC \.bb2
; CHECK:     BNE \.bb1
; CHECK:     CMP
; CHECK:     BCC \.bb2
; CHECK:     BNE \.bb1
; CHECK:     CMP
; CHECK:     BCC \.bb2
; CHECK:     JMP \.bb1

func @TestSge32 : (i32, i32) -> i8 {
bb0(%0 : i32, %1 : i32):
    %2 : i1 = arith.cmpi sge, %0, %1
    cf.cond_br %2, bb1(), bb2()
bb1():
    %3 : i8 = arith.constant 1
    core.return %3
bb2():
    %4 : i8 = arith.constant 0
    core.return %4
}
