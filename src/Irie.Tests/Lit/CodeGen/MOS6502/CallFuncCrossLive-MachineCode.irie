; RUN: @iriec --target mos6502 --emit=asm @file

; Verifies that implicit-defs on mos6502.jsr.abs shorten live ranges: %0 is
; live across the first call (used as arg to the second call), so the RA
; must NOT keep it in a caller-saved physreg. MOS6502CallLowering marks $a,
; $x, $y, all flag regs, and RC2..RC15 as clobbered. RC16..RC31 are left
; out of the clobber set as a stopgap "callee-saved" pool, giving the
; allocator somewhere to park cross-call values without spilling. This is
; a temporary measure — once frame slots / true spilling land (steps 11+),
; all RC* should be marked caller-saved per CC_MOS.
;
; For the test: %0 starts in $a (entry-block livein) and needs to survive
; the first JSR. The RA picks RC16 (first non-clobbered RC), so the lowering
; is:
;   STA $10  — preserve %0 to RC16 (address $10) before consumption
;   JSR      — call 1 (the arg is already in $a, untouched by the STA;
;              clobbers $a, but %0 lives in $10)
;   LDA $10  — reload %0 into $a as the arg for the second JSR
;   JSR      — call 2 (clobbers $a again, but %0 isn't used after)
;   RTS
;
; The save/restore run `$zp16 = $a ; $a = $zp16` that the RA emits before the
; first JSR collapses: MOS6502ParallelCopyPass resolves it to the net parallel
; copy {$zp16 <- $a} ($a keeps its entry value), so the redundant reload before
; the first call is dropped — $a already holds the argument.

; CHECK: TestCrossCall:
; CHECK:     STA \$10
; CHECK:     JSR Callee
; CHECK:     LDA \$10
; CHECK:     JSR Callee
; CHECK:     RTS

func @TestCrossCall : (i8) -> i8 {
bb0(%0 : i8):
    %1 : i8 = call.func @Callee, %0
    %2 : i8 = call.func @Callee, %0
    core.return %2
}
