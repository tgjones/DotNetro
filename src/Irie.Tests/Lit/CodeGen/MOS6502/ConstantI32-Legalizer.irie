; RUN: @iriec --target mos6502 --stop-after Legalizer @file

; Checks the unified-MIR legalizer pass: a wide 32-bit `arith.constant` is
; split into four narrow 8-bit `arith.constant` operations (NarrowScalar
; action) in LSB-first order, then re-merged with `pseudo.merge` into the
; original i32 def vreg.
;
; The pseudo.merge inserted around the narrowed constants is folded by the
; LegalizationArtifactCombiner against the surrounding ABI-lowering
; pseudo.unmerge, so the per-byte constants feed directly into the return
; byte copies.
;
; The value 0x01020304 makes the LSB-first ordering obvious: byte 0 is 4,
; byte 1 is 3, byte 2 is 2, byte 3 is 1.

; CHECK: func @TestConstant : () -> i32 {
; CHECK: bb0():
; CHECK:     %5 : i8 = arith.constant 4
; CHECK:     %6 : i8 = arith.constant 3
; CHECK:     %7 : i8 = arith.constant 2
; CHECK:     %8 : i8 = arith.constant 1
; CHECK:     $a = pseudo.copy %5
; CHECK:     $x = pseudo.copy %6
; CHECK:     $zp2 = pseudo.copy %7
; CHECK:     $zp3 = pseudo.copy %8
; CHECK:     pseudo.return
; CHECK: }

func @TestConstant : () -> i32 {
bb0():
    %0 : i32 = arith.constant 16909060
    core.return %0
}
