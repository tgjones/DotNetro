; RUN: @iriec --target mos6502 --stop-after irtranslator @file

; Checks that a 32-bit integer add at the IR-translator boundary produces
; CC_MOS-shaped GenericCopy/GenericMerge plumbing around a single GenericAdd,
; before legalization splits it into a per-byte ADC chain.

; CHECK: func @TestFunction \{
; CHECK:   bb0\(\):
; CHECK:     liveins: \$A, \$X, \$RC2, \$RC3, \$RC4, \$RC5, \$RC6, \$RC7
; CHECK:     %0:i8 = GenericCopy \$A
; CHECK:     %1:i8 = GenericCopy \$X
; CHECK:     %2:i8 = GenericCopy \$RC2
; CHECK:     %3:i8 = GenericCopy \$RC3
; CHECK:     %4:i32 = GenericMerge %0, %1, %2, %3
; CHECK:     %5:i8 = GenericCopy \$RC4
; CHECK:     %6:i8 = GenericCopy \$RC5
; CHECK:     %7:i8 = GenericCopy \$RC6
; CHECK:     %8:i8 = GenericCopy \$RC7
; CHECK:     %9:i32 = GenericMerge %5, %6, %7, %8
; CHECK:     %10:i32 = GenericAdd %4, %9
; CHECK:     %11:i8, %12:i8, %13:i8, %14:i8 = GenericUnmerge %10
; CHECK:     \$A = GenericCopy %11
; CHECK:     \$X = GenericCopy %12
; CHECK:     \$RC2 = GenericCopy %13
; CHECK:     \$RC3 = GenericCopy %14
; CHECK:     RTS_Implied implicit \$A, implicit \$X, implicit \$RC2, implicit \$RC3
; CHECK: \}

func @TestFunction : (i32, i32) -> i32 {
bb0(%0 : i32, %1 : i32):
  %2 = integer_add %0, %1
  return %2
}
