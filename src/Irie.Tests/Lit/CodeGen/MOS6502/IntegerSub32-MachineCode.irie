; RUN: @iriec --target mos6502 --emit=asm @file

; End-to-end check: IntegerSub32 lowers all the way to MOS6502 assembly text
; via the MachineCodeEmitter. Same shape as IntegerAdd32-MachineCode.irie,
; with SEC/SBC instead of CLC/ADC.

; CHECK: TestFunction:
; CHECK:     SEC
; CHECK:     SBC \$04
; CHECK:     STA \$04
; CHECK:     TXA
; CHECK:     SBC \$05
; CHECK:     STA \$08
; CHECK:     LDA \$02
; CHECK:     STA \$09
; CHECK:     LDA \$08
; CHECK:     STA \$05
; CHECK:     LDA \$06
; CHECK:     STA \$02
; CHECK:     LDA \$09
; CHECK:     SBC \$02
; CHECK:     STA \$06
; CHECK:     LDA \$03
; CHECK:     STA \$08
; CHECK:     LDA \$06
; CHECK:     STA \$02
; CHECK:     LDA \$07
; CHECK:     STA \$03
; CHECK:     LDA \$08
; CHECK:     SBC \$03
; CHECK:     STA \$03
; CHECK:     LDA \$04
; CHECK:     LDX \$05
; CHECK:     RTS

func @TestFunction : (i32, i32) -> i32 {
bb0(%0 : i32, %1 : i32):
    %2 : i32 = arith.subi %0, %1
    core.return %2
}
