; RUN: @iriec --target mos6502 --emit=asm @file

; @WriteLineInt32 from runtime.irie: prints a signed 32-bit integer in decimal
; followed by CR. Hand-written, fully-lowered MOS6502 MIR (the generic i32
; magnitude loop overruns the spill-free register allocator). Ported from
; BbcMicroCodeGenerator.CompileSystemConsoleWriteLineInt32. The i32 argument
; arrives LSB-first in $a, $x, $zp2, $zp3 per CC_MOS. Plan §6 step 6.
;
; We spot-check the structural landmarks: the value bytes copied into working
; zero-page, the sign test (the redundant `CMP #$00` after `LDA $07` is dropped
; by MOS6502LateOptimization — the LDA already set N for the BPL), the '-' +
; two's-complement negate path, and the CR (#$0D) / osasci tail that terminates
; the line.

; CHECK: WriteLineInt32:
; CHECK:     STA \$04
; CHECK:     STX \$05
; CHECK:     LDA \$07
; CHECK:     BPL \.bb2
; CHECK:     LDA #\$2D
; CHECK:     JSR osasci
; CHECK:     CLC
; CHECK:     EOR #\$FF
; CHECK:     ADC #\$01
; CHECK:     LDA #\$0D
; CHECK:     JSR osasci
; CHECK:     RTS

func @osasci : (i8) -> void {
bb0(%0 : i8):
    mos6502.jsr.abs 65507
    mos6502.rts
}

func @WriteLineInt32 : (i32) -> void {
bb0(%0 : i32):
    ; Copy the incoming value bytes into working zero-page slots zp4..zp7.
    $16 = mos6502.sta.zp $0
    $17 = mos6502.stx.zp $1
    $0 = mos6502.lda.zp $14
    $18 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $15
    $19 = mos6502.sta.zp $0
    ; Zero the pad flag and the printed-something flag.
    $0 = mos6502.lda.imm 0
    $20 = mos6502.sta.zp $0
    $25 = mos6502.sta.zp $0
    ; Sign test: CMP #0 sets N = bit7 of the MSB.
    $0 = mos6502.lda.zp $19
    mos6502.cmp.imm $0, 0, implicit-def $6, implicit-def $8, implicit-def $5
    mos6502.bpl bb2, implicit $6
    mos6502.jmp.abs bb1
bb1():
    ; Negative: print '-' then two's-complement negate the value.
    $0 = mos6502.lda.imm 45
    mos6502.jsr.abs @osasci, implicit $0
    $5 = mos6502.clc
    $0 = mos6502.lda.zp $16
    $0 = mos6502.eor.imm $0, 255
    $0, $5 = mos6502.adc.imm $0, 1, $5
    $16 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $17
    $0 = mos6502.eor.imm $0, 255
    $0, $5 = mos6502.adc.imm $0, 0, $5
    $17 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $18
