func @osasci : (i8) -> void {
bb0(%0 : i8):
    mos6502.jsr.abs 65507
    mos6502.rts
}

func @WriteLineInt32 : (i32) -> void {
bb0(%0 : i32):
    ; Copy the incoming value bytes into working zero-page slots zp4..zp7.
    $16 = mos6502.sta.zp $0
    $17 = mos6502.stx.zp $1
    $0 = mos6502.lda.zp $14
    $18 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $15
    $19 = mos6502.sta.zp $0
    ; Zero the pad flag and the printed-something flag.
    $0 = mos6502.lda.imm 0
    $20 = mos6502.sta.zp $0
    $25 = mos6502.sta.zp $0
    ; Sign test: CMP #0 sets N = bit7 of the MSB.
    $0 = mos6502.lda.zp $19
    mos6502.cmp.imm $0, 0, implicit-def $6, implicit-def $8, implicit-def $5
    mos6502.bpl bb2, implicit $6
    mos6502.jmp.abs bb1
bb1():
    ; Negative: print '-' then two's-complement negate the value.
    $0 = mos6502.lda.imm 45
    mos6502.jsr.abs @osasci, implicit $0
    $5 = mos6502.clc
    $0 = mos6502.lda.zp $16
    $0 = mos6502.eor.imm $0, 255
    $0, $5 = mos6502.adc.imm $0, 1, $5
    $16 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $17
    $0 = mos6502.eor.imm $0, 255
    $0, $5 = mos6502.adc.imm $0, 0, $5
    $17 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $18
    $0 = mos6502.eor.imm $0, 255
    $0, $5 = mos6502.adc.imm $0, 0, $5
    $18 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $19
    $0 = mos6502.eor.imm $0, 255
    $0, $5 = mos6502.adc.imm $0, 0, $5
    $19 = mos6502.sta.zp $0
    mos6502.jmp.abs bb2
bb2():
    mos6502.jmp.abs bb3
bb3():
    ; --- power 1000000000 ---
    $0 = mos6502.lda.imm 0
    $21 = mos6502.sta.zp $0
    $0 = mos6502.lda.imm 202
    $22 = mos6502.sta.zp $0
    $0 = mos6502.lda.imm 154
    $23 = mos6502.sta.zp $0
    $0 = mos6502.lda.imm 59
    $24 = mos6502.sta.zp $0
    $1 = mos6502.ldx.imm 0
    mos6502.jmp.abs bb4
bb4():
    $5 = mos6502.sec
    $0 = mos6502.lda.zp $16
    $0, $5 = mos6502.sbc.zp $0, $21, $5
    $16 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $17
    $0, $5 = mos6502.sbc.zp $0, $22, $5
    $17 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $18
    $0, $5 = mos6502.sbc.zp $0, $23, $5
    $18 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $19
    $0, $5 = mos6502.sbc.zp $0, $24, $5
    $19 = mos6502.sta.zp $0
    mos6502.bcs bb5, implicit $5
    mos6502.jmp.abs bb6
bb5():
    $1 = mos6502.inx
    mos6502.jmp.abs bb4
bb6():
    ; value < power: restore by adding power back, emit digit
    $5 = mos6502.clc
    $0 = mos6502.lda.zp $16
    $0, $5 = mos6502.adc.zp $0, $21, $5
    $16 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $17
    $0, $5 = mos6502.adc.zp $0, $22, $5
    $17 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $18
    $0, $5 = mos6502.adc.zp $0, $23, $5
    $18 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $19
    $0, $5 = mos6502.adc.zp $0, $24, $5
    $19 = mos6502.sta.zp $0
    mos6502.jmp.abs bb7
bb7():
    $0 = mos6502.txa
    mos6502.cmp.imm $0, 0, implicit-def $6, implicit-def $8, implicit-def $5
    mos6502.bne bb9, implicit $8
    mos6502.jmp.abs bb8
bb8():
    $0 = mos6502.lda.zp $20
    mos6502.cmp.imm $0, 0, implicit-def $6, implicit-def $8, implicit-def $5
    mos6502.beq bb10, implicit $8
    $0 = mos6502.lda.imm 0
    mos6502.jmp.abs bb9
bb9():
    $0 = mos6502.ora.imm $0, 48
    $25 = mos6502.sta.zp $0
    $0 = mos6502.lda.imm 48
    $20 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $25
    mos6502.jsr.abs @osasci, implicit $0
    mos6502.jmp.abs bb10
bb10():
    mos6502.jmp.abs bb11
bb11():
    ; --- power 100000000 ---
    $0 = mos6502.lda.imm 0
    $21 = mos6502.sta.zp $0
