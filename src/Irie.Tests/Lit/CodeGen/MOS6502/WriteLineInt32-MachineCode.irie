    $0, $5 = mos6502.adc.imm $0, 0, $5
    $18 = mos6502.sta.zp $0
    $0 = mos6502.lda.zp $19
    $0 = mos6502.eor.imm $0, 255
    $0, $5 = mos6502.adc.imm $0, 0, $5
    $19 = mos6502.sta.zp $0
    mos6502.jmp.abs bb2
bb2():
    mos6502.jmp.abs bb3
bb3():
