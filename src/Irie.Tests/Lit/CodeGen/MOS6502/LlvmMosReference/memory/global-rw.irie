; RUN: @iriec --target mos6502 --emit=asm @file

; Corpus: llvm-mos-reference/memory/global-rw
; Faithful read-modify-write of a global with an arg-supplied delta:
;   int counter; int global_rw(int delta) { counter += delta; return counter; }
; via mem.symbol / mem.load.i16 / mem.store.i16 with absolute addressing.
;
; The result bytes are stored with STY/STX absolute directly from the registers
; they already occupy ($y low, $x high) — the generic st.abs reads its value in
; place via its Axy operand class, refined to sty.abs/stx.abs post-RA — rather than
; funnelling each byte back through $a. This is a 10-instruction match for
; llvm-mos (ext/llvm-mos-reference/memory/global-rw.s).
;
; CHECK pins Irie's current --emit=asm output (characterization / golden).

; CHECK: global_rw:
; CHECK:     CLC
; CHECK:     ADC counter
; CHECK:     TAY
; CHECK:     TXA
; CHECK:     ADC counter\+1
; CHECK:     TAX
; CHECK:     STY counter
; CHECK:     STX counter\+1
; CHECK:     TYA
; CHECK:     RTS

global @counter : i16 = bytes "\x00\x00"
func @global_rw : (i16) -> i16 {
bb0(%0 : i16):
    %1 : i16 = mem.symbol @counter
    %2 : i16 = mem.load.i16 %1
    %3 : i16 = arith.addi %2, %0
    mem.store.i16 %1, %3
    core.return %3
}
