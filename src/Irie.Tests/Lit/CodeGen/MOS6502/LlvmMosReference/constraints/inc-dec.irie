; RUN: @iriec --target mos6502 --emit=asm @file

; Corpus: llvm-mos-reference/constraints/inc-dec
;   char inc_dec(char a, char b) { a++; b--; return a + b; }
; Named for INC/DEC vs INX/INY register pinning, but llvm-mos constant-folds the
; whole body to `a + b` in its target-independent InstCombine pass and emits 4
; instructions identical to add-i8 (stx; clc; adc; rts). `ArithSimplifyPass` —
; Irie's scoped InstCombine/Reassociate analogue — performs the same fold:
; `(a+1) + (b-1)` linearizes to terms {a, b} with net constant 0, so the `+1`/`-1`
; cancel and the body becomes a single `arith.addi %a, %b`. This is now a clean
; apples-to-apples parity case with the corpus .s.
;
; The shared constant 1 is spelled as an `arith.constant 1 : i8` def, the
; generic-MIR idiom for a literal (an inline immediate in a generic value slot is
; a verifier error, not "not selectable"). After ArithSimplify folds the body, the
; constant def is dead-code-eliminated.
;
; CHECK pins Irie's current --emit=asm output (characterization / golden),
; generated mechanically from iriec and verified under `dotnet test`.

; CHECK: inc_dec:
; CHECK:     STX \$02
; CHECK:     CLC
; CHECK:     ADC \$02
; CHECK:     RTS

func @inc_dec : (i8, i8) -> i8 {
bb0(%0 : i8, %1 : i8):
    %2 : i8 = arith.constant 1
    %3 : i8 = arith.addi %0, %2
    %4 : i8 = arith.subi %1, %2
    %5 : i8 = arith.addi %3, %4
    core.return %5
}
