; RUN: @iriec --target mos6502 --emit=asm @file

; Corpus: llvm-mos-reference/control-flow/if-else
; Signed absolute difference a>b ? a-b : b-a (written a<b ? b-a : a-b, with the
; branch arms swapped so the compare stays a single signed less-than): a diamond
; whose two arms subtract in opposite orders and merge via a phi (cross-block
; liveness + phi coalescing). The compare is signed (arith.cmpi slt) to match
; the C source's `int a > int b`; using unsigned here would diverge for
; negative operands.
;
; CHECK pins Irie's current --emit=asm output (characterization / golden).
; Compare against ext/llvm-mos-reference/control-flow/if-else.s; close gaps via irie-report.

; CHECK:     abs_diff:
; CHECK:     STA \$07
; CHECK:     STX \$06
; CHECK:     LDY \$02
; CHECK:     STY \$05
; CHECK:     LDY \$03
; CHECK:     STY \$04
; CHECK:     LDY \$02
; CHECK:     STY \$08
; CHECK:     STA \$09
; CHECK:     TXA
; CHECK:     LDX \$03
; CHECK:     LDY \$09
; CHECK:     STY \$03
; CHECK:     EOR \#\$80
; CHECK:     TAY
; CHECK:     TXA
; CHECK:     EOR \#\$80
; CHECK:     STA \$02
; CHECK:     TYA
; CHECK:     CMP \$02
; CHECK:     BCC \.bb1
; CHECK:     BNE \.bb2
; CHECK:     LDA \$03
; CHECK:     CMP \$08
; CHECK:     BCC \.bb1
; CHECK:     JMP \.bb2
; CHECK:     \.bb1:
; CHECK:     SEC
; CHECK:     LDA \$05
; CHECK:     SBC \$07
; CHECK:     TAY
; CHECK:     LDA \$04
; CHECK:     SBC \$06
; CHECK:     TAX
; CHECK:     JMP \.bb3
; CHECK:     \.bb2:
; CHECK:     SEC
; CHECK:     LDA \$07
; CHECK:     SBC \$05
; CHECK:     TAY
; CHECK:     LDA \$06
; CHECK:     SBC \$04
; CHECK:     TAX
; CHECK:     JMP \.bb3
; CHECK:     \.bb3:
; CHECK:     TYA
; CHECK:     RTS

func @abs_diff : (i16, i16) -> i16 {
bb0(%0 : i16, %1 : i16):
    %2 : i1 = arith.cmpi slt, %0, %1
    cf.cond_br %2, bb1(), bb2()
bb1():
    %3 : i16 = arith.subi %1, %0
    cf.br bb3(%3)
bb2():
    %4 : i16 = arith.subi %0, %1
    cf.br bb3(%4)
bb3(%5 : i16):
    core.return %5
}
