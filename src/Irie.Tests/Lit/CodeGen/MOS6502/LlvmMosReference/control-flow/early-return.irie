; RUN: @iriec --target mos6502 --emit=asm @file

; Corpus: llvm-mos-reference/control-flow/early-return
; Guard clauses with multiple early returns: three signed `< 0` tests, each on a
; separate i16 argument, with staggered live-range ends. Faithful to the C source
; (ext/llvm-mos-reference/control-flow/early-return.c).
;
; Each `x < 0` lowers to a sign-bit test of the high byte only (CMP #$00 + BMI),
; matching llvm-mos's `cpx #0 ; bmi` — see MOS6502InstructionSelector's
; SelectCmpIMultiByte zero-RHS signed fast path. The high byte is brought in by a
; flag-setting `LDA`, so MOS6502LateOptimization drops the redundant `CMP #$00`:
; the BMI reads the N that LDA already set (llvm-mos folds the same way).
;
; The `a + b` sub-expression is computed in BOTH the `c < 0` exit (`return a + b`)
; and the fall-through (`return a + b + c`). HoistCommonCodePass — the local
; SimplifyCFG `hoistCommonCodeFromSuccessors` analogue — hoists that shared add
; into the `c < 0` test block (the sole predecessor of both arms), so it is
; emitted once: the `c < 0` arm branches to the return tail with `a + b` already
; in Y/X, and the fall-through only adds `c`. This matches llvm-mos, which
; likewise computes `a + b` once in the `c`-test block and reuses it.
;
; The `core.return` blocks are then merged into one common return block by
; ReturnMergePass (the SimplifyCFG `tailMergeBlocksWithSimilarFunctionTerminators`
; analogue), so the i16 return epilogue is emitted once: paths funnel into the
; shared `.bb4: TYA ; RTS` tail (low in Y/A, high in X), reached by fall-through
; (.bb3), `BMI .bb4` (the `c < 0` arm), and `JMP .bb4` (.bb5, the `return a` arm).
; This matches llvm-mos's shared `bb.5` tail.
;
; CHECK pins Irie's current --emit=asm output (characterization / golden).
; Compare against ext/llvm-mos-reference/control-flow/early-return.s; close gaps via irie-report.

; CHECK: early_return:
; CHECK:     STA \$07
; CHECK:     STX \$06
; CHECK:     LDY \#\$00
; CHECK:     LDX \#\$00
; CHECK:     LDA \$06
; CHECK:     BMI \.bb4
; CHECK: \.bb1:
; CHECK:     LDA \$03
; CHECK:     BMI \.bb5
; CHECK: \.bb2:
; CHECK:     CLC
; CHECK:     LDA \$07
; CHECK:     ADC \$02
; CHECK:     TAY
; CHECK:     LDA \$06
; CHECK:     ADC \$03
; CHECK:     TAX
; CHECK:     LDA \$05
; CHECK:     BMI \.bb4
; CHECK: \.bb3:
; CHECK:     CLC
; CHECK:     TYA
; CHECK:     ADC \$04
; CHECK:     TAY
; CHECK:     TXA
; CHECK:     ADC \$05
; CHECK:     TAX
; CHECK: \.bb4:
; CHECK:     TYA
; CHECK:     RTS
; CHECK: \.bb5:
; CHECK:     LDY \$07
; CHECK:     LDX \$06
; CHECK:     JMP \.bb4

func @early_return : (i16, i16, i16) -> i16 {
bb0(%0 : i16, %1 : i16, %2 : i16):
    %3 : i16 = arith.constant 0
    %4 : i1 = arith.cmpi slt, %0, %3
    cf.cond_br %4, bb1(), bb2()
bb1():
    core.return %3
bb2():
    %5 : i1 = arith.cmpi slt, %1, %3
    cf.cond_br %5, bb3(), bb4()
bb3():
    core.return %0
bb4():
    %6 : i1 = arith.cmpi slt, %2, %3
    cf.cond_br %6, bb5(), bb6()
bb5():
    %7 : i16 = arith.addi %0, %1
    core.return %7
bb6():
    %8 : i16 = arith.addi %0, %1
    %9 : i16 = arith.addi %8, %2
    core.return %9
}
