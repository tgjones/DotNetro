; RUN: @iriec --target mos6502 --emit=asm @file

; Corpus: llvm-mos-reference/control-flow/common-subexpr
; A faithful mirror of ext/llvm-mos-reference/control-flow/common-subexpr.c:
;   int g0,g1,g2,g3;
;   void common_subexpr(int a,int b,int c,int d) {
;       if (c < 0) { g0 = d + 1; g1 = a + b; }
;       else       { g0 = d - 1; g2 = a + b; g3 = d; }
;   }
; A diamond whose two arms share a common sub-expression (a + b) that is NOT the
; leading computation of either arm: each arm first computes a different value
; (d + 1 vs d - 1, stored to g0) and only then the shared a + b.
;
; Motivation: this exercised a gap in HoistCommonCodePass — the local SimplifyCFG
; `hoistCommonCodeFromSuccessors` analogue. It originally only matched when the
; *first* instruction of every successor was identical; here each arm leads with a
; different op (`arith.addi %3, 1` vs `arith.subi %3, 1`), so the match failed and
; the shared `a + b` below it was never hoisted — the two-byte add was emitted
; twice. HoistCommonCodePass now skips the non-matching leading ops and hoists the
; shared `a + b` once, above the surviving branch (mirroring llvm-mos's real
; `hoistCommonCodeFromSuccessors`; GVNHoist is the further generalization to any
; common dominator). In the CHECK below the carry-chain add (`CLC / ADC $04 ...
; ADC $02`) now appears once in the entry block before `BMI .bb3`, and each arm
; just stores the precomputed value to its own global.
;
; The residual gap vs the corpus .s (39 instrs) is register pressure, not the
; hoist: holding `a + b` live across the branch alongside the fourth i16 arg
; (`d`, kept for the `g3 = d` store) oversubscribes the three real registers, so
; RA keeps values in the zero-page register file and copies them into {$a,$x,$y}
; just-in-time at each absolute store (`LDX $03 / STX g2`, `LDX $07 / STX g3+1`),
; mirroring llvm-mos greedy `tryInstructionSplit` ("effectively spilling to a
; register") — no `pseudo.spill`, GPRs materialized at the stores.

; CHECK: common_subexpr:
; CHECK: LDY \$02
; CHECK: STY \$04
; CHECK: LDY \$03
; CHECK: STY \$02
; CHECK: LDY \$06
; CHECK: CLC
; CHECK: ADC \$04
; CHECK: STA \$03
; CHECK: TXA
; CHECK: ADC \$02
; CHECK: STA \$02
; CHECK: LDA \$05
; CHECK: BMI \.bb3
; CHECK: \.bb1:
; CHECK: SEC
; CHECK: TYA
; CHECK: SBC \#\$01
; CHECK: TAX
; CHECK: LDA \$07
; CHECK: SBC \#\$00
; CHECK: STX g0
; CHECK: STA g0\+1
; CHECK: LDX \$03
; CHECK: STX g2
; CHECK: LDX \$02
; CHECK: STX g2\+1
; CHECK: STY g3
; CHECK: LDX \$07
; CHECK: STX g3\+1
; CHECK: \.bb2:
; CHECK: RTS
; CHECK: \.bb3:
; CHECK: CLC
; CHECK: TYA
; CHECK: ADC \#\$01
; CHECK: TAX
; CHECK: LDA \$07
; CHECK: ADC \#\$00
; CHECK: STX g0
; CHECK: STA g0\+1
; CHECK: LDX \$03
; CHECK: STX g1
; CHECK: LDX \$02
; CHECK: STX g1\+1
; CHECK: RTS

global @g0 : i16 = bytes "\x00\x00"
global @g1 : i16 = bytes "\x00\x00"
global @g2 : i16 = bytes "\x00\x00"
global @g3 : i16 = bytes "\x00\x00"
func @common_subexpr : (i16, i16, i16, i16) -> void {
bb0(%0 : i16, %1 : i16, %2 : i16, %3 : i16):
    %4 : i16 = arith.constant 0
    %5 : i16 = arith.constant 1
    %6 : i1 = arith.cmpi slt, %2, %4
    cf.cond_br %6, bb1(), bb2()
bb1():                                  ; c < 0:  g0 = d + 1; g1 = a + b
    %7 : i16 = arith.addi %3, %5
    %8 : i16 = mem.symbol @g0
    mem.store.i16 %8, %7
    %9 : i16 = arith.addi %0, %1
    %10 : i16 = mem.symbol @g1
    mem.store.i16 %10, %9
    core.return
bb2():                                  ; c >= 0: g0 = d - 1; g2 = a + b; g3 = d
    %11 : i16 = arith.subi %3, %5
    %12 : i16 = mem.symbol @g0
    mem.store.i16 %12, %11
    %13 : i16 = arith.addi %0, %1
    %14 : i16 = mem.symbol @g2
    mem.store.i16 %14, %13
    %15 : i16 = mem.symbol @g3
    mem.store.i16 %15, %3
    core.return
}
