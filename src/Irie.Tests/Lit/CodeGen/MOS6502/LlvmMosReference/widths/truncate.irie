; RUN: @iriec --target mos6502 --emit=asm @file

; Corpus: llvm-mos-reference/widths/truncate
;   char truncate(int a, int b) { return (char)(a + b); }
; Two i16 args, added, then truncated to i8. Truncation drops the high byte of
; the sum, so its live range ends early and the high-byte add is dead. The
; legalizer's cascade DCE (CascadeErase, mirroring llvm::eraseInstrs) erases the
; folded merge, then the now-dead high-byte add, then that add's argument copies
; — so the high byte is never computed.
;
; At parity with ext/llvm-mos-reference/widths/truncate.s (`clc; adc __rc2; rts`).

; CHECK:     truncate:
; CHECK:         CLC
; CHECK:         ADC \$02
; CHECK:         RTS

func @truncate : (i16, i16) -> i8 {
bb0(%0 : i16, %1 : i16):
    %2 : i16 = arith.addi %0, %1
    %3 : i8 = cast.trunc %2
    core.return %3
}
