; RUN: @iriec --target mos6502 --emit=asm @file

; Corpus: llvm-mos-reference/basics/ret-const
; Materialize an i16 constant into the return registers ($a/$x); no inputs
; live.
;
; CHECK pins Irie's current --emit=asm output (characterization / golden).
; Compare against ext/llvm-mos-reference/basics/ret-const.s; close gaps via irie-report.

; CHECK: ret_const:
; CHECK:     LDA \#\$D2
; CHECK:     LDX \#\$04
; CHECK:     RTS

func @ret_const : () -> i16 {
bb0():
    %0 : i16 = arith.constant 1234
    core.return %0
}
