; RUN: @iriec --target mos6502 --stop-after VirtualRegisterRewriter @file

; Checks the post-VirtualRegisterRewriter shape of IntegerAdd32.
;
; After VirtualRegisterRewriterPass:
; - All virtual registers have been assigned physical registers
; - GenericCopy chains are preserved (to be eliminated by CopyEliminationPass)
; - ADC instructions now use physical registers

; CHECK: func @TestFunction \{
; CHECK:   bb0\(\):
; CHECK:     liveins: \$A, \$X, \$RC2, \$RC3, \$RC4, \$RC5, \$RC6, \$RC7
; CHECK:     \$A = GenericCopy \$A
; CHECK:     \$A = GenericCopy \$X
; CHECK:     \$A = GenericCopy \$RC2
; CHECK:     \$A = GenericCopy \$RC3
; CHECK:     \$RC2 = GenericCopy \$RC4
; CHECK:     \$RC3 = GenericCopy \$RC5
; CHECK:     \$RC4 = GenericCopy \$RC6
; CHECK:     \$RC5 = GenericCopy \$RC7
; CHECK:     \$C = LDImm1 0
; CHECK:     \$A, \$C = ADC_ZeroPage \$A, \$RC2, \$C
; CHECK:     \$A = GenericCopy \$A
; CHECK:     \$A, \$C = ADC_ZeroPage \$A, \$RC3, \$C
; CHECK:     \$A = GenericCopy \$A
; CHECK:     \$A, \$C = ADC_ZeroPage \$A, \$RC4, \$C
; CHECK:     \$A = GenericCopy \$A
; CHECK:     \$A, \$C = ADC_ZeroPage \$A, \$RC5, \$C
; CHECK:     \$A = GenericCopy \$A
; CHECK:     \$A = GenericCopy \$A
; CHECK:     \$X = GenericCopy \$A
; CHECK:     \$RC2 = GenericCopy \$A
; CHECK:     \$RC3 = GenericCopy \$A
; CHECK:     RTS_Implied implicit \$A, implicit \$X, implicit \$RC2, implicit \$RC3
; CHECK: \}

func @TestFunction : (i32, i32) -> i32 {
bb0(%0 : i32, %1 : i32):
  %2 = integer_add %0, %1
  return %2
}
