; RUN: @iriec --target mos6502 --emit=bin --origin=0x1000 @file | @irie-mc --hex-dump

; Verifies that a multi-item initializer is concatenated in order: raw bytes
; followed by a 2-byte LE symbol reference.
;
; Layout starting at $1000:
;   $1000: RTS              ; 60     — @entry
;   $1001: RTS              ; 60     — @foo
;   $1002: 'A' 'B'          ; 41 42  — @x first item (2 bytes)
;   $1004: 01 10            ;        — @x second item: LE address of @foo at $1001

; CHECK: 00000000: 60 60 41 42 01 10

func @entry : () -> void {
bb0():
    mos6502.rts
}

func @foo : () -> void {
bb0():
    mos6502.rts
}

global @x : i32 = [bytes "AB", @foo]
