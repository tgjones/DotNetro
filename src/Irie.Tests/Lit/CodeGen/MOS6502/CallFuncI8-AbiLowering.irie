; RUN: @iriec --target mos6502 --stop-after AbiLowering @file

; Checks call.func lowering: the call op is replaced by per-arg pseudo.copy
; into CC_MOS arg physregs, followed by mos6502.jsr.abs (with implicit-uses
; on arg physregs and implicit-defs on every caller-saved physreg), followed
; by per-return pseudo.copy out of the return physreg.

; CHECK: func @TestCall : \(i8\) -> i8 \{
; CHECK:   bb0\(\):
; CHECK:     \[liveins: \$a\]
; CHECK:     %0 : i8 = pseudo.copy \$a
; CHECK:     \$a = pseudo.copy %0
; CHECK:     mos6502.jsr.abs @Callee, implicit \$a, implicit-def \$a, implicit-def \$x, implicit-def \$y, implicit-def \$c, implicit-def \$n, implicit-def \$v, implicit-def \$z, implicit-def \$i, implicit-def \$d, implicit-def \$b, implicit-def \$zp2, implicit-def \$zp3, implicit-def \$zp4, implicit-def \$zp5, implicit-def \$zp6, implicit-def \$zp7, implicit-def \$zp8, implicit-def \$zp9, implicit-def \$zp10, implicit-def \$zp11, implicit-def \$zp12, implicit-def \$zp13, implicit-def \$zp14, implicit-def \$zp15
; CHECK:     %1 : i8 = pseudo.copy \$a
; CHECK:     \$a = pseudo.copy %1
; CHECK:     pseudo.return
; CHECK: \}

func @TestCall : (i8) -> i8 {
bb0(%0 : i8):
    %1 : i8 = call.func @Callee, %0
    core.return %1
}
