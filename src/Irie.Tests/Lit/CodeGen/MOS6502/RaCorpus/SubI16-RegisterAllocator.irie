; RUN: @iriec --target mos6502 --stop-after RegisterAllocator @file

; Derived from reference-register-allocator/basics/sub-i16.
; Subtraction is non-commutative, so the minuend is pinned to $a -- the operand
; order is fixed, unlike add where either operand can take the tied slot.

; CHECK: func @sub_i16 : \(i16, i16\) -> i16 \{
; CHECK: bb0\(\):
; CHECK:     \[liveins: \$a, \$x, \$zp2, \$zp3\]
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     \$x = pseudo\.copy \$x
; CHECK:     \$zp2 = pseudo\.copy \$zp2
; CHECK:     \$zp3 = pseudo\.copy \$zp3
; CHECK:     \$c = mos6502\.sec
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     \$a, \$c = mos6502\.sbc \$a, \$zp2, \$c
; CHECK:     \$zp2 = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$x
; CHECK:     \$a, \$c = mos6502\.sbc \$a, \$zp3, \$c
; CHECK:     \$x = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$zp2
; CHECK:     \$x = pseudo\.copy \$x
; CHECK:     mos6502\.rts implicit \$a, implicit \$x
; CHECK: \}

func @sub_i16 : (i16, i16) -> i16 {
bb0(%0 : i16, %1 : i16):
    %2 : i16 = arith.subi %0, %1
    core.return %2
}
