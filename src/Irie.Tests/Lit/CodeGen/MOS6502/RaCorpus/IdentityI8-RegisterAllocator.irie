; RUN: @iriec --target mos6502 --stop-after RegisterAllocator @file

; Derived from reference-register-allocator/basics/identity-i8.
; The i8 arg arrives in $a and is also the i8 return register, so the ideal
; result is (near) no moves. (Note: i8 *arithmetic* is not yet selectable in
; Irie, but a pure i8 passthrough is.)

; CHECK: func @identity_i8 : \(i8\) -> i8 \{
; CHECK: bb0\(\):
; CHECK:     \[liveins: \$a\]
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     mos6502\.rts implicit \$a
; CHECK: \}

func @identity_i8 : (i8) -> i8 {
bb0(%0 : i8):
    core.return %0
}
