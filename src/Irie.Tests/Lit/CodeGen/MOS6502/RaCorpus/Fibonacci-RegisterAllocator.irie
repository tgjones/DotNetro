; RUN: @iriec --target mos6502 --stop-after RegisterAllocator @file

; Derived from reference-register-allocator/realistic/fibonacci. Iterative
; Fibonacci: a loop carrying a pair of values rotated each iteration
; (a, b = b, a + b), plus an induction counter. The rotation is a copy cycle
; inside a loop, mixing coalescing pressure with back-edge liveness -- a compact
; but rich RA case. This is one of the realistic cases the register-allocator
; redesign Phase 4 unblocked: the old allocator aborted with "no free physical
; register" here. The new allocator allocates it with NO spill -- all three
; loop-carried i16 pairs plus the per-iteration temp fit in the zero-page
; register file, and the rotation lowers to a shuffle of zp copies at the loop
; tail (the $zp7/$x and $zp9/$zp8 pairs are rotated through $zp3/$zp2).
;
; Reference (llvm-mos fibonacci.mir) keeps the carried pair in $a/$x and the zp
; pool and splits the loop preheader; Irie keeps everything in the zp pool and
; never uses $y (the register-preference divergence tracked for Phase 5). The
; point pinned here is that the copy-cycle-in-a-loop now allocates at all,
; without spilling.

; CHECK: func @fibonacci : \(i16\) -> i16 \{
; CHECK: bb0\(\):
; CHECK:     \[liveins: \$a, \$x\]
; CHECK:     \$zp11 = pseudo\.copy \$a
; CHECK:     \$zp10 = pseudo\.copy \$x
; CHECK:     \$zp7 = pseudo\.copy 0
; CHECK:     \$zp6 = pseudo\.copy 0
; CHECK:     \$zp9 = pseudo\.copy 1
; CHECK:     \$zp8 = pseudo\.copy 0
; CHECK:     \$zp5 = pseudo\.copy 0
; CHECK:     \$zp4 = pseudo\.copy 0
; CHECK:     \$zp7 = pseudo\.copy \$zp7
; CHECK:     \$zp6 = pseudo\.copy \$zp6
; CHECK:     \$zp9 = pseudo\.copy \$zp9
; CHECK:     \$zp8 = pseudo\.copy \$zp8
; CHECK:     \$zp5 = pseudo\.copy \$zp5
; CHECK:     \$zp4 = pseudo\.copy \$zp4
; CHECK:     mos6502\.jmp\.abs bb1
; CHECK: bb1\(\):
; CHECK:     \[liveins: \$zp11, \$zp10, \$zp7, \$zp6, \$zp9, \$zp8, \$zp5, \$zp4\]
; CHECK:     \$zp3 = pseudo\.copy \$zp5
; CHECK:     \$a = pseudo\.copy \$zp4
; CHECK:     \$zp12 = pseudo\.copy \$zp11
; CHECK:     \$x = pseudo\.copy \$zp10
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     \$a = mos6502\.eor\.imm \$a, 128
; CHECK:     \$y = pseudo\.copy \$a
; CHECK:     \$y = pseudo\.copy \$y
; CHECK:     \$x = pseudo\.copy \$x
; CHECK:     \$a = pseudo\.copy \$x
; CHECK:     \$a = mos6502\.eor\.imm \$a, 128
; CHECK:     \$zp2 = pseudo\.copy \$a
; CHECK:     \$zp2 = pseudo\.copy \$zp2
; CHECK:     \$a = pseudo\.copy \$y
; CHECK:     mos6502\.cmp \$a, \$zp2, implicit-def \$n, implicit-def \$z, implicit-def \$c
; CHECK:     mos6502\.bcc bb2, implicit \$c
; CHECK:     mos6502\.bne bb3, implicit \$z
; CHECK:     \$a = pseudo\.copy \$zp3
; CHECK:     mos6502\.cmp \$a, \$zp12, implicit-def \$n, implicit-def \$z, implicit-def \$c
; CHECK:     mos6502\.bcc bb2, implicit \$c
; CHECK:     mos6502\.jmp\.abs bb3
; CHECK: bb2\(\):
; CHECK:     \[liveins: \$zp11, \$zp10, \$zp7, \$zp6, \$zp9, \$zp8, \$zp5, \$zp4\]
; CHECK:     \$c = mos6502\.clc
; CHECK:     \$a = pseudo\.copy \$zp7
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp9, \$c
; CHECK:     \$y = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$zp6
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp8, \$c
; CHECK:     \$x = pseudo\.copy \$a
; CHECK:     \$zp3 = pseudo\.copy 1
; CHECK:     \$zp2 = pseudo\.copy 0
; CHECK:     \$c = mos6502\.clc
; CHECK:     \$a = pseudo\.copy \$zp5
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp3, \$c
; CHECK:     \$zp5 = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$zp4
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp2, \$c
; CHECK:     \$zp4 = pseudo\.copy \$a
; CHECK:     \$zp7 = pseudo\.copy \$zp9
; CHECK:     \$zp6 = pseudo\.copy \$zp8
; CHECK:     \$zp9 = pseudo\.copy \$y
; CHECK:     \$zp8 = pseudo\.copy \$x
; CHECK:     \$zp5 = pseudo\.copy \$zp5
; CHECK:     \$zp4 = pseudo\.copy \$zp4
; CHECK:     mos6502\.jmp\.abs bb1
; CHECK: bb3\(\):
; CHECK:     \[liveins: \$zp7, \$zp6\]
; CHECK:     \$a = pseudo\.copy \$zp7
; CHECK:     \$x = pseudo\.copy \$zp6
; CHECK:     mos6502\.rts implicit \$a, implicit \$x
; CHECK: \}

func @fibonacci : (i16) -> i16 {
bb0(%0 : i16):
    %1 : i16 = arith.constant 0
    %2 : i16 = arith.constant 1
    %3 : i16 = arith.constant 0
    cf.br bb1(%1, %2, %3)
bb1(%4 : i16, %5 : i16, %6 : i16):
    %7 : i1 = arith.cmpi slt, %6, %0
    cf.cond_br %7, bb2(), bb3()
bb2():
    %8 : i16 = arith.addi %4, %5
    %9 : i16 = arith.constant 1
    %10 : i16 = arith.addi %6, %9
    cf.br bb1(%5, %8, %10)
bb3():
    core.return %4
}
