; RUN: @iriec --target mos6502 --stop-after RegisterAllocator @file

; Derived from reference-register-allocator/pressure/many-calls — the corpus's
; genuine register-pressure SPILL case. Ten i16 values (twenty bytes) are kept
; live across a call, but a call clobbers all but the callee-saved zero-page
; slots ($zp16..$zp31, sixteen bytes), so two bytes cannot stay in registers and
; must spill to memory. This is the case the register-allocator redesign Phase 4
; (spilling + rematerialization) unblocks: the old allocator threw
; "no free physical register" here.
;
; The spilled bytes are NON-rematerializable (each is computed by an adc chain,
; not a constant), so they take the store/reload path: a `pseudo.spill <slot>`
; after the def (before the call) and a `pseudo.reload <slot>` before the use
; (after the call). The allocator mints two ABSTRACT frame slots (i8, no physical
; address) — printed in the function header as `frame_slot N : i8 @...`. A future
; static-stack pass places them in zero page / .bss
; (notes/static-stack-alloc-plan.md). Only two bytes spill: the zero-page file
; absorbs the rest, exactly as the plan predicts for this target.
;
; CHECK lines are an ordered subsequence (DotLit matches each after the previous),
; pinning the spill mechanics rather than every line of the long adc chain.

; CHECK: func @pressure : \(i16, i16\) -> i16 \{
; CHECK:   frame_slot 0 : i8 @pressure_spill300
; CHECK:   frame_slot 1 : i8 @pressure_spill299
; CHECK: bb0\(\):
; CHECK:     \[liveins: \$a, \$x, \$zp2, \$zp3\]
; The two cross-call bytes are stored to their abstract slots before the call …
; CHECK:     pseudo\.spill 1, \$a
; CHECK:     pseudo\.spill 0, \$a
; CHECK:     mos6502\.jsr\.abs @use
; … and reloaded from those slots after the call, into fresh tiny vregs.
; CHECK:     \$zp4 = pseudo\.reload 1
; CHECK:     \$zp4 = pseudo\.reload 0
; CHECK:     mos6502\.rts implicit \$a, implicit \$x

func @use : (i16) -> i16 {
bb0(%0 : i16):
    core.return %0
}
func @pressure : (i16, i16) -> i16 {
bb0(%0 : i16, %1 : i16):
    %2 : i16 = arith.addi %0, %1
    %3 : i16 = arith.addi %2, %1
    %4 : i16 = arith.addi %3, %1
    %5 : i16 = arith.addi %4, %1
    %6 : i16 = arith.addi %5, %1
    %7 : i16 = arith.addi %6, %1
    %8 : i16 = arith.addi %7, %1
    %9 : i16 = arith.addi %8, %1
    %10 : i16 = arith.addi %9, %1
    %11 : i16 = call.func @use, %0
    %12 : i16 = arith.addi %2, %3
    %13 : i16 = arith.addi %12, %4
    %14 : i16 = arith.addi %13, %5
    %15 : i16 = arith.addi %14, %6
    %16 : i16 = arith.addi %15, %7
    %17 : i16 = arith.addi %16, %8
    %18 : i16 = arith.addi %17, %9
    %19 : i16 = arith.addi %18, %10
    %20 : i16 = arith.addi %19, %11
    core.return %20
}
