; RUN: @iriec --target mos6502 --stop-after RegisterAllocator @file

; Derived from reference-register-allocator/memory/global-rw, simplified.
; Read-modify-write of a global via mem.symbol / mem.load.i16 / mem.store.i16.
; The corpus version adds an arg-supplied delta that stays live across the load;
; that extra pressure overflows the no-spill RA, so this uses a constant delta.
; (mem.load only supports mem.symbol addresses today, so the pointer cases
; ptr-deref / array-index are not yet expressible.)

; CHECK: global @counter : i16 = bytes "\\x00\\x00"
; CHECK: func @global_incr : \(\) -> i16 \{
; CHECK: bb0\(\):
; CHECK:     \$a = mos6502\.lda\.imm\.symlo @counter
; CHECK:     \$zp0 = pseudo\.copy \$a
; CHECK:     \$a = mos6502\.lda\.imm\.symhi @counter
; CHECK:     \$zp1 = pseudo\.copy \$a
; CHECK:     \$y = mos6502\.ldy\.imm 0
; CHECK:     \$y = pseudo\.copy \$y
; CHECK:     \$a = mos6502\.lda\.indy \$zp0, implicit \$zp1, implicit \$y
; CHECK:     \$zp2 = pseudo\.copy \$a
; CHECK:     \$y = mos6502\.ldy\.imm 1
; CHECK:     \$y = pseudo\.copy \$y
; CHECK:     \$a = mos6502\.lda\.indy \$zp0, implicit \$zp1, implicit \$y
; CHECK:     \$x = pseudo\.copy \$a
; CHECK:     \$zp4 = pseudo\.copy 1
; CHECK:     \$zp3 = pseudo\.copy 0
; CHECK:     \$c = mos6502\.clc
; CHECK:     \$a = pseudo\.copy \$zp2
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp4, \$c
; CHECK:     \$zp2 = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$x
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp3, \$c
; CHECK:     \$x = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$zp2
; CHECK:     \$y = mos6502\.ldy\.imm 0
; CHECK:     \$y = pseudo\.copy \$y
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     mos6502\.sta\.indy \$zp0, \$a, implicit \$zp1, implicit \$y
; CHECK:     \$a = pseudo\.copy \$x
; CHECK:     \$y = mos6502\.ldy\.imm 1
; CHECK:     \$y = pseudo\.copy \$y
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     mos6502\.sta\.indy \$zp0, \$a, implicit \$zp1, implicit \$y
; CHECK:     \$a = pseudo\.copy \$zp2
; CHECK:     \$x = pseudo\.copy \$x
; CHECK:     mos6502\.rts implicit \$a, implicit \$x
; CHECK: \}

global @counter : i16 = bytes "\x00\x00"
func @global_incr : () -> i16 {
bb0():
    %0 : i16 = mem.symbol @counter
    %1 : i16 = mem.load.i16 %0
    %2 : i16 = arith.constant 1
    %3 : i16 = arith.addi %1, %2
    mem.store.i16 %0, %3
    core.return %3
}
