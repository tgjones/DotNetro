; RUN: @iriec --target mos6502 --stop-after RegisterAllocator @file

; Derived from reference-register-allocator/control-flow/early-return.
; A guard clause: one early exit, plus a fall-through that consumes all three
; args. (The full corpus version chains three guards; that pressure exceeds the
; current no-spill RA, so this is the largest early-return shape Irie allocates
; today.)

; CHECK: func @early_return : \(i16, i16, i16\) -> i16 \{
; CHECK: bb0\(\):
; CHECK:     \[liveins: \$a, \$x, \$zp2, \$zp3, \$zp4, \$zp5\]
; CHECK:     \$zp6 = pseudo\.copy \$a
; CHECK:     \$x = pseudo\.copy \$x
; CHECK:     \$zp2 = pseudo\.copy \$zp2
; CHECK:     \$zp3 = pseudo\.copy \$zp3
; CHECK:     \$zp4 = pseudo\.copy \$zp4
; CHECK:     \$zp5 = pseudo\.copy \$zp5
; CHECK:     \$zp7 = pseudo\.copy 0
; CHECK:     \$zp8 = pseudo\.copy 0
; CHECK:     \$zp9 = pseudo\.copy \$zp6
; CHECK:     \$zp10 = pseudo\.copy \$x
; CHECK:     \$zp11 = pseudo\.copy \$zp7
; CHECK:     \$zp12 = pseudo\.copy \$zp8
; CHECK:     \$zp10 = pseudo\.copy \$zp10
; CHECK:     \$a = pseudo\.copy \$zp10
; CHECK:     \$a = mos6502\.eor\.imm \$a, 128
; CHECK:     \$zp10 = pseudo\.copy \$a
; CHECK:     \$zp10 = pseudo\.copy \$zp10
; CHECK:     \$zp12 = pseudo\.copy \$zp12
; CHECK:     \$a = pseudo\.copy \$zp12
; CHECK:     \$a = mos6502\.eor\.imm \$a, 128
; CHECK:     \$zp12 = pseudo\.copy \$a
; CHECK:     \$zp12 = pseudo\.copy \$zp12
; CHECK:     \$a = pseudo\.copy \$zp10
; CHECK:     mos6502\.cmp \$a, \$zp12, implicit-def \$n, implicit-def \$z, implicit-def \$c
; CHECK:     mos6502\.bcc bb1, implicit \$c
; CHECK:     mos6502\.bne bb2, implicit \$z
; CHECK:     \$a = pseudo\.copy \$zp9
; CHECK:     mos6502\.cmp \$a, \$zp11, implicit-def \$n, implicit-def \$z, implicit-def \$c
; CHECK:     mos6502\.bcc bb1, implicit \$c
; CHECK:     mos6502\.jmp\.abs bb2
; CHECK: bb1\(\):
; CHECK:     \[liveins: \$zp7, \$zp8\]
; CHECK:     \$a = pseudo\.copy \$zp7
; CHECK:     \$x = pseudo\.copy \$zp8
; CHECK:     mos6502\.rts implicit \$a, implicit \$x
; CHECK: bb2\(\):
; CHECK:     \[liveins: \$zp2, \$zp4, \$zp3, \$zp5, \$zp6, \$x\]
; CHECK:     \$c = mos6502\.clc
; CHECK:     \$a = pseudo\.copy \$zp2
; CHECK:     \$zp2 = pseudo\.copy \$zp4
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp2, \$c
; CHECK:     \$zp2 = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$zp3
; CHECK:     \$zp3 = pseudo\.copy \$zp5
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp3, \$c
; CHECK:     \$zp3 = pseudo\.copy \$a
; CHECK:     \$c = mos6502\.clc
; CHECK:     \$a = pseudo\.copy \$zp2
; CHECK:     \$zp2 = pseudo\.copy \$zp6
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp2, \$c
; CHECK:     \$zp2 = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$zp3
; CHECK:     \$zp3 = pseudo\.copy \$x
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp3, \$c
; CHECK:     \$zp3 = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$zp2
; CHECK:     \$x = pseudo\.copy \$zp3
; CHECK:     mos6502\.rts implicit \$a, implicit \$x
; CHECK: \}

func @early_return : (i16, i16, i16) -> i16 {
bb0(%0 : i16, %1 : i16, %2 : i16):
    %3 : i16 = arith.constant 0
    %4 : i1 = arith.cmpi slt, %0, %3
    cf.cond_br %4, bb1(), bb2()
bb1():
    core.return %3
bb2():
    %5 : i16 = arith.addi %1, %2
    %6 : i16 = arith.addi %5, %0
    core.return %6
}
