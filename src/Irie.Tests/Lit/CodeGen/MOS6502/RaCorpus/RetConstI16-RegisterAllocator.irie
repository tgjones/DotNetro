; RUN: @iriec --target mos6502 --stop-after RegisterAllocator @file

; Derived from reference-register-allocator/basics/ret-const.
; Materialize an i16 constant into the return registers ($a/$x); no inputs live.

; CHECK: func @ret_const : \(\) -> i16 \{
; CHECK: bb0\(\):
; CHECK:     \$zp2 = pseudo\.copy 210
; CHECK:     \$zp3 = pseudo\.copy 4
; CHECK:     \$a = pseudo\.copy \$zp2
; CHECK:     \$x = pseudo\.copy \$zp3
; CHECK:     mos6502\.rts implicit \$a, implicit \$x
; CHECK: \}

func @ret_const : () -> i16 {
bb0():
    %0 : i16 = arith.constant 1234
    core.return %0
}
