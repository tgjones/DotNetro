; RUN: @iriec --target mos6502 --stop-after RegisterAllocator @file

; Derived from reference-register-allocator/basics/add-i16.
; i16 add = a 2-byte carry chain (mos6502.adc x2 threading $c).
; Convergence (register-allocator-redesign Phase 5, the "$y gap" closure): like
; the llvm-mos reference, Irie now parks the low result byte in the real register
; $y while the high byte is computed in $a — the cost-driven colour preference
; promotes a scarce GPR for this short cross-instruction value. Before Phase 5
; Irie parked it in $zp2 and never touched $y.

; CHECK: func @add_i16 : \(i16, i16\) -> i16 \{
; CHECK: bb0\(\):
; CHECK:     \[liveins: \$a, \$x, \$zp2, \$zp3\]
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     \$x = pseudo\.copy \$x
; CHECK:     \$zp2 = pseudo\.copy \$zp2
; CHECK:     \$zp3 = pseudo\.copy \$zp3
; CHECK:     \$c = mos6502\.clc
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp2, \$c
; CHECK:     \$y = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$x
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp3, \$c
; CHECK:     \$x = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$y
; CHECK:     \$x = pseudo\.copy \$x
; CHECK:     mos6502\.rts implicit \$a, implicit \$x
; CHECK: \}

func @add_i16 : (i16, i16) -> i16 {
bb0(%0 : i16, %1 : i16):
    %2 : i16 = arith.addi %0, %1
    core.return %2
}
