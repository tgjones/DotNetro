; RUN: @iriec --target mos6502 --stop-after RegisterAllocator @file

; Derived from reference-register-allocator/control-flow/loop-counter. A counted
; loop with two loop-carried i16 values -- an induction counter and an
; accumulator -- both live across the back edge, so their registers must be
; stable around the loop. This is the canonical loop case the register-allocator
; redesign Phase 4 unblocked: the old allocator aborted with "no free physical
; register" on any counted loop because the back-edge liveness raised pressure it
; could not relieve. The new allocator allocates it with NO spill -- the two
; carried values get stable zero-page homes ($zp7/$zp6 for the counter pair,
; $zp5/$x for the accumulator pair) that persist across the back edge, and the
; zero-page file absorbs the rest, exactly as the plan predicts for this target.
;
; The corpus source is `for (i=0; i<n; i++) s += i;`. llvm-mos (loop-counter.mir)
; strength-reduces that whole loop to a closed-form multiply via __mulsi3 -- a
; high-level optimisation Irie's pipeline does not perform and which is unrelated
; to register allocation. This test keeps a genuine loop (the carried values are
; advanced by constant deltas so the induction var is never reused in conflicting
; operand roles -- which would otherwise hit the same isel class-assignment gap
; noted in IfElse), pinning what the redesigned RA does for loop-carried liveness.

; CHECK: func @loop_sum : \(i16\) -> i16 \{
; CHECK: bb0\(\):
; CHECK:     \[liveins: \$a, \$x\]
; CHECK:     \$zp9 = pseudo\.copy \$a
; CHECK:     \$zp8 = pseudo\.copy \$x
; CHECK:     \$zp5 = pseudo\.copy 0
; CHECK:     \$zp4 = pseudo\.copy 0
; CHECK:     \$zp7 = pseudo\.copy \$zp5
; CHECK:     \$zp6 = pseudo\.copy \$zp4
; CHECK:     \$zp5 = pseudo\.copy \$zp5
; CHECK:     \$zp4 = pseudo\.copy \$zp4
; CHECK:     mos6502\.jmp\.abs bb1
; CHECK: bb1\(\):
; CHECK:     \[liveins: \$zp9, \$zp8, \$zp7, \$zp6, \$zp5, \$zp4\]
; CHECK:     \$zp3 = pseudo\.copy \$zp7
; CHECK:     \$a = pseudo\.copy \$zp6
; CHECK:     \$zp10 = pseudo\.copy \$zp9
; CHECK:     \$x = pseudo\.copy \$zp8
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     \$a = mos6502\.eor\.imm \$a, 128
; CHECK:     \$y = pseudo\.copy \$a
; CHECK:     \$y = pseudo\.copy \$y
; CHECK:     \$x = pseudo\.copy \$x
; CHECK:     \$a = pseudo\.copy \$x
; CHECK:     \$a = mos6502\.eor\.imm \$a, 128
; CHECK:     \$zp2 = pseudo\.copy \$a
; CHECK:     \$zp2 = pseudo\.copy \$zp2
; CHECK:     \$a = pseudo\.copy \$y
; CHECK:     mos6502\.cmp \$a, \$zp2, implicit-def \$n, implicit-def \$z, implicit-def \$c
; CHECK:     mos6502\.bcc bb2, implicit \$c
; CHECK:     mos6502\.bne bb3, implicit \$z
; CHECK:     \$a = pseudo\.copy \$zp3
; CHECK:     mos6502\.cmp \$a, \$zp10, implicit-def \$n, implicit-def \$z, implicit-def \$c
; CHECK:     mos6502\.bcc bb2, implicit \$c
; CHECK:     mos6502\.jmp\.abs bb3
; CHECK: bb2\(\):
; CHECK:     \[liveins: \$zp9, \$zp8, \$zp7, \$zp6, \$zp5, \$zp4\]
; CHECK:     \$zp3 = pseudo\.copy 3
; CHECK:     \$zp2 = pseudo\.copy 0
; CHECK:     \$c = mos6502\.clc
; CHECK:     \$a = pseudo\.copy \$zp5
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp3, \$c
; CHECK:     \$zp5 = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$zp4
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp2, \$c
; CHECK:     \$zp4 = pseudo\.copy \$a
; CHECK:     \$zp3 = pseudo\.copy 1
; CHECK:     \$zp2 = pseudo\.copy 0
; CHECK:     \$c = mos6502\.clc
; CHECK:     \$a = pseudo\.copy \$zp7
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp3, \$c
; CHECK:     \$zp7 = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$zp6
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp2, \$c
; CHECK:     \$zp6 = pseudo\.copy \$a
; CHECK:     \$zp7 = pseudo\.copy \$zp7
; CHECK:     \$zp6 = pseudo\.copy \$zp6
; CHECK:     \$zp5 = pseudo\.copy \$zp5
; CHECK:     \$zp4 = pseudo\.copy \$zp4
; CHECK:     mos6502\.jmp\.abs bb1
; CHECK: bb3\(\):
; CHECK:     \[liveins: \$zp5, \$zp4\]
; CHECK:     \$a = pseudo\.copy \$zp5
; CHECK:     \$x = pseudo\.copy \$zp4
; CHECK:     mos6502\.rts implicit \$a, implicit \$x
; CHECK: \}

func @loop_sum : (i16) -> i16 {
bb0(%0 : i16):
    %1 : i16 = arith.constant 0
    cf.br bb1(%1, %1)
bb1(%2 : i16, %3 : i16):
    %4 : i1 = arith.cmpi slt, %2, %0
    cf.cond_br %4, bb2(), bb3()
bb2():
    %5 : i16 = arith.constant 3
    %6 : i16 = arith.addi %3, %5
    %7 : i16 = arith.constant 1
    %8 : i16 = arith.addi %2, %7
    cf.br bb1(%8, %6)
bb3():
    core.return %3
}
