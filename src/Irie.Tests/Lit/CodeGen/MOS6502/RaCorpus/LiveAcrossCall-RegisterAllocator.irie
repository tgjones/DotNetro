; RUN: @iriec --target mos6502 --stop-after RegisterAllocator @file

; Derived from reference-register-allocator/pressure/live-across-call.
; The arg must survive the call to @g (which clobbers caller-saved registers)
; so it can be added to the result. llvm-mos keeps it in a callee-saved $rc;
; watch where Irie places it across the mos6502.jsr.

; CHECK: func @g : \(i16\) -> i16 \{
; CHECK: bb0\(\):
; CHECK:     \[liveins: \$a, \$x\]
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     \$x = pseudo\.copy \$x
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     \$x = pseudo\.copy \$x
; CHECK:     mos6502\.rts implicit \$a, implicit \$x
; CHECK: \}
; CHECK: func @live_across_call : \(i16\) -> i16 \{
; CHECK: bb0\(\):
; CHECK:     \[liveins: \$a, \$x\]
; CHECK:     \$zp16 = pseudo\.copy \$a
; CHECK:     \$zp17 = pseudo\.copy \$x
; CHECK:     \$a = pseudo\.copy \$zp16
; CHECK:     \$x = pseudo\.copy \$zp17
; CHECK:     mos6502\.jsr\.abs @g, implicit \$a, implicit \$x, implicit-def \$a, implicit-def \$x, implicit-def \$y, implicit-def \$c, implicit-def \$n, implicit-def \$v, implicit-def \$z, implicit-def \$i, implicit-def \$d, implicit-def \$b, implicit-def \$zp2, implicit-def \$zp3, implicit-def \$zp4, implicit-def \$zp5, implicit-def \$zp6, implicit-def \$zp7, implicit-def \$zp8, implicit-def \$zp9, implicit-def \$zp10, implicit-def \$zp11, implicit-def \$zp12, implicit-def \$zp13, implicit-def \$zp14, implicit-def \$zp15
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     \$x = pseudo\.copy \$x
; CHECK:     \$c = mos6502\.clc
; CHECK:     \$a = pseudo\.copy \$a
; CHECK:     \$zp2 = pseudo\.copy \$zp16
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp2, \$c
; CHECK:     \$zp2 = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$x
; CHECK:     \$zp3 = pseudo\.copy \$zp17
; CHECK:     \$a, \$c = mos6502\.adc \$a, \$zp3, \$c
; CHECK:     \$zp3 = pseudo\.copy \$a
; CHECK:     \$a = pseudo\.copy \$zp2
; CHECK:     \$x = pseudo\.copy \$zp3
; CHECK:     mos6502\.rts implicit \$a, implicit \$x
; CHECK: \}

func @g : (i16) -> i16 {
bb0(%0 : i16):
    core.return %0
}
func @live_across_call : (i16) -> i16 {
bb0(%0 : i16):
    %1 : i16 = call.func @g, %0
    %2 : i16 = arith.addi %1, %0
    core.return %2
}
