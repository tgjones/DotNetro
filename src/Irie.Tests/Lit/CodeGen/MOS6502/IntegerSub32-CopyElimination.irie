; RUN: @iriec --target mos6502 --stop-after CopyElimination @file

; Checks the unified-MIR pipeline output after CopyElimination on a
; subtraction. Same shape as IntegerAdd32-CopyElimination.irie, with sec/sbc.

; CHECK: func @TestFunction : (i32, i32) -> i32 {
; CHECK: bb0():
; CHECK:     [liveins: $a, $x, $zp2, $zp3, $zp4, $zp5, $zp6, $zp7]
; CHECK:     $c = mos6502.sec
; CHECK:     $a, $c = mos6502.sbc $a, $zp4, $c
; CHECK:     $y = pseudo.copy $a
; CHECK:     $a = pseudo.copy $x
; CHECK:     $a, $c = mos6502.sbc $a, $zp5, $c
; CHECK:     $x = pseudo.copy $a
; CHECK:     $a = pseudo.copy $zp2
; CHECK:     $a, $c = mos6502.sbc $a, $zp6, $c
; CHECK:     $zp2 = pseudo.copy $a
; CHECK:     $a = pseudo.copy $zp3
; CHECK:     $a, $c = mos6502.sbc $a, $zp7, $c
; CHECK:     $zp3 = pseudo.copy $a
; CHECK:     $a = pseudo.copy $y
; CHECK:     mos6502.rts implicit $a, implicit $x, implicit $zp2, implicit $zp3
; CHECK: }

func @TestFunction : (i32, i32) -> i32 {
bb0(%0 : i32, %1 : i32):
    %2 : i32 = arith.subi %0, %1
    core.return %2
}
