; RUN: @iriec --target mos6502 --stop-after TwoAddressInstruction @file

; Checks the unified-MIR two-address instruction pass on subtraction. Each
; `mos6502.sbc` has a `(tied-def 0)` use; the pass inserts an explicit
; `pseudo.copy` before each sbc to materialize the tied use as a fresh def
; of the def[0] vreg, so RA can pick a single physreg for both ends.

; CHECK: func @TestFunction : \(i32, i32\) -> i32 \{
; CHECK:   bb0\(\):
; CHECK:     \[liveins: \$a, \$x, \$zp2, \$zp3, \$zp4, \$zp5, \$zp6, \$zp7\]
; CHECK:     %3 : ac = pseudo.copy \$a
; CHECK:     %4 : ac = pseudo.copy \$x
; CHECK:     %5 : ac = pseudo.copy \$zp2
; CHECK:     %6 : ac = pseudo.copy \$zp3
; CHECK:     %7 : zp = pseudo.copy \$zp4
; CHECK:     %8 : zp = pseudo.copy \$zp5
; CHECK:     %9 : zp = pseudo.copy \$zp6
; CHECK:     %10 : zp = pseudo.copy \$zp7
; CHECK:     %32 : cc = mos6502.sec
; CHECK:     %33 : ac = pseudo.copy %3
; CHECK:     %33 : ac, %34 : cc = mos6502.sbc %33\(tied-def 0\), %7, %32
; CHECK:     %35 : ac = pseudo.copy %4
; CHECK:     %35 : ac, %36 : cc = mos6502.sbc %35\(tied-def 0\), %8, %34
; CHECK:     %37 : ac = pseudo.copy %5
; CHECK:     %37 : ac, %38 : cc = mos6502.sbc %37\(tied-def 0\), %9, %36
; CHECK:     %39 : ac = pseudo.copy %6
; CHECK:     %39 : ac, %40 : cc = mos6502.sbc %39\(tied-def 0\), %10, %38
; CHECK:     \$a = pseudo.copy %33
; CHECK:     \$x = pseudo.copy %35
; CHECK:     \$zp2 = pseudo.copy %37
; CHECK:     \$zp3 = pseudo.copy %39
; CHECK:     mos6502.rts implicit \$a, implicit \$x, implicit \$zp2, implicit \$zp3
; CHECK: \}

func @TestFunction : (i32, i32) -> i32 {
bb0(%0 : i32, %1 : i32):
    %2 : i32 = arith.subi %0, %1
    core.return %2
}
