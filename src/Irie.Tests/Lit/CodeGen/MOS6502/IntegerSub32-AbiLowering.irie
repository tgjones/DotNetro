; RUN: @iriec --target mos6502 --stop-after AbiLowering @file

; Checks the unified-MIR ABI-lowering pass on a 32-bit subtraction. ABI
; lowering is op-agnostic, so the resulting MIR is identical in shape to
; IntegerAdd32-AbiLowering.irie except that the wide op is `arith.subi`.

; CHECK: func @TestFunction : (i32, i32) -> i32 {
; CHECK: bb0():
; CHECK:     [liveins: $a, $x, $zp2, $zp3, $zp4, $zp5, $zp6, $zp7]
; CHECK:     %3 : i8 = pseudo.copy $a
; CHECK:     %4 : i8 = pseudo.copy $x
; CHECK:     %5 : i8 = pseudo.copy $zp2
; CHECK:     %6 : i8 = pseudo.copy $zp3
; CHECK:     %0 : i32 = pseudo.merge %3, %4, %5, %6
; CHECK:     %7 : i8 = pseudo.copy $zp4
; CHECK:     %8 : i8 = pseudo.copy $zp5
; CHECK:     %9 : i8 = pseudo.copy $zp6
; CHECK:     %10 : i8 = pseudo.copy $zp7
; CHECK:     %1 : i32 = pseudo.merge %7, %8, %9, %10
; CHECK:     %2 : i32 = arith.subi %0, %1
; CHECK:     %11 : i8, %12 : i8, %13 : i8, %14 : i8 = pseudo.unmerge %2
; CHECK:     $a = pseudo.copy %11
; CHECK:     $x = pseudo.copy %12
; CHECK:     $zp2 = pseudo.copy %13
; CHECK:     $zp3 = pseudo.copy %14
; CHECK:     pseudo.return
; CHECK: }

func @TestFunction : (i32, i32) -> i32 {
bb0(%0 : i32, %1 : i32):
    %2 : i32 = arith.subi %0, %1
    core.return %2
}
