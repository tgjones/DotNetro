; RUN: @iriec --target mos6502 --emit=asm @file

; Regression guard for the $a-scratch clobber of zero-page-routed pseudo.copies.
;
; The i32 parameter arrives LSB-first in $a, $x, $zp2, $zp3 (CC_MOS live-ins).
; Adding a constant 1 to it materializes the four constant bytes with
; `LDA #imm ; STA $zp`, and each `LDA #imm` clobbers $a. Byte 0 of the
; parameter lives in $a on entry, so RA must evict it to a zero-page slot
; *before* the first const-materialization clobbers $a, then reload it for the
; ADC. Before this fix RA kept the live-in in $a across the const setup, so the
; `LDA #$01` destroyed the parameter byte and the function returned 1 + 0
; instead of param + 1.
;
; The load-bearing lines: $a (the param's byte 0) is stashed with `STA $04`
; ahead of the first `LDA #$01`, and the per-byte ADC reads it back with
; `LDA $04` — never adding into a clobbered accumulator.

; CHECK: M:
; CHECK:     STA \$04
; CHECK:     LDA #\$01
; CHECK:     STA \$05
; CHECK:     LDA #\$00
; CHECK:     STA \$06
; CHECK:     LDA #\$00
; CHECK:     STA \$07
; CHECK:     LDA #\$00
; CHECK:     STA \$08
; CHECK:     CLC
; CHECK:     LDA \$04
; CHECK:     ADC \$05

func @M : (i32) -> i32 {
bb0(%0 : i32):
    %1 : i32 = arith.constant 1
    %2 : i32 = arith.addi %0, %1
    core.return %2
}
