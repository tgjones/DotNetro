; RUN: @iriec --target mos6502 --stop-after legalizer @file

; Checks that legalization splits a 32-bit GenericAdd into a chain of four
; 8-bit GenericAddCarry operations (NarrowScalar action), threaded through
; the C flag via i1 carry-in/carry-out vregs. The chain head's carry-in is
; an explicit GenericConstant i1 0 (mirrors llvm-mos's
; MOSLegalizerInfo::legalizeAddSubO, which also materializes a buildConstant
; for G_UADDO → G_UADDE), so every AddCarry has a uniform 3-use shape.
;
; The Merge/Unmerge artifacts inserted by NarrowScalar around the per-byte
; chain are folded away by the LegalizationArtifactCombiner, so the chain
; feeds directly off the parameter copies and into the return-value copies.

; CHECK: func @TestFunction \{
; CHECK:   bb0\(\):
; CHECK:     liveins: \$A, \$X, \$RC2, \$RC3, \$RC4, \$RC5, \$RC6, \$RC7
; CHECK:     %0:i8 = GenericCopy \$A
; CHECK:     %1:i8 = GenericCopy \$X
; CHECK:     %2:i8 = GenericCopy \$RC2
; CHECK:     %3:i8 = GenericCopy \$RC3
; CHECK:     %5:i8 = GenericCopy \$RC4
; CHECK:     %6:i8 = GenericCopy \$RC5
; CHECK:     %7:i8 = GenericCopy \$RC6
; CHECK:     %8:i8 = GenericCopy \$RC7
; CHECK:     %23:i1 = GenericConstant 0
; CHECK:     %24:i8, %25:i1 = GenericAddCarry %0, %5, %23
; CHECK:     %26:i8, %27:i1 = GenericAddCarry %1, %6, %25
; CHECK:     %28:i8, %29:i1 = GenericAddCarry %2, %7, %27
; CHECK:     %30:i8, %31:i1 = GenericAddCarry %3, %8, %29
; CHECK:     \$A = GenericCopy %24
; CHECK:     \$X = GenericCopy %26
; CHECK:     \$RC2 = GenericCopy %28
; CHECK:     \$RC3 = GenericCopy %30
; CHECK:     RTS_Implied implicit \$A, implicit \$X, implicit \$RC2, implicit \$RC3
; CHECK: \}

func @TestFunction : (i32, i32) -> i32 {
bb0(%0 : i32, %1 : i32):
  %2 = integer_add %0, %1
  return %2
}
