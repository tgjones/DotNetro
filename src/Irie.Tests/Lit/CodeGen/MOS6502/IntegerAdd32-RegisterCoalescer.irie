; RUN: @iriec --target mos6502 --stop-after RegisterCoalescer @file

; Checks that RegisterCoalescerPass eliminates the four vreg-to-vreg copies
; inserted by TwoAddressInstructionPass.
;
; Each TwoAddr copy  "%Ndef = GenericCopy %Nsrc"  is coalesced by merging the
; source vreg into the destination vreg:
;   - %0:Ac  merged into %33:Ac  (both :Ac, %0 killed at the copy)
;   - %1:Ac  merged into %35:Ac
;   - %2:Ac  merged into %37:Ac
;   - %3:Ac  merged into %39:Ac
;
; The 8 argument/return copies (vreg = GenericCopy $physreg) are preserved;
; physreg coalescing is handled later by the RA + CopyEliminationPass.

; CHECK: func @TestFunction \{
; CHECK:   bb0\(\):
; CHECK:     liveins: \$A, \$X, \$RC2, \$RC3, \$RC4, \$RC5, \$RC6, \$RC7
; CHECK:     %33:Ac = GenericCopy \$A
; CHECK:     %35:Ac = GenericCopy \$X
; CHECK:     %37:Ac = GenericCopy \$RC2
; CHECK:     %39:Ac = GenericCopy \$RC3
; CHECK:     %5:Imag8 = GenericCopy \$RC4
; CHECK:     %6:Imag8 = GenericCopy \$RC5
; CHECK:     %7:Imag8 = GenericCopy \$RC6
; CHECK:     %8:Imag8 = GenericCopy \$RC7
; CHECK:     %32:Cc = LDImm1 0
; CHECK:     %33:Ac, %34:Cc = ADC_ZeroPage %33:Ac\(tied-def 0\), %5:Imag8, %32:Cc
; CHECK:     %35:Ac, %36:Cc = ADC_ZeroPage %35:Ac\(tied-def 0\), %6:Imag8, %34:Cc
; CHECK:     %37:Ac, %38:Cc = ADC_ZeroPage %37:Ac\(tied-def 0\), %7:Imag8, %36:Cc
; CHECK:     %39:Ac, %40:Cc = ADC_ZeroPage %39:Ac\(tied-def 0\), %8:Imag8, %38:Cc
; CHECK:     \$A = GenericCopy %33:Ac
; CHECK:     \$X = GenericCopy %35:Ac
; CHECK:     \$RC2 = GenericCopy %37:Ac
; CHECK:     \$RC3 = GenericCopy %39:Ac
; CHECK:     RTS_Implied implicit \$A, implicit \$X, implicit \$RC2, implicit \$RC3
; CHECK: \}

func @TestFunction : (i32, i32) -> i32 {
bb0(%0 : i32, %1 : i32):
  %2 = integer_add %0, %1
  return %2
}
