; RUN: @iriec --target mos6502-bbcmicro --emit=asm @file

; Absolute-overflow fallback for static frame placement.
;
; @big is non-reentrant, but its nine i32 frame slots total 36 bytes — more
; than the 32-byte zero-page window ($70..$8F) the BBC Micro subtarget owns.
; MOS6502FramePlacementPass therefore leaves @big's slots in absolute memory
; (StackId default): each access keeps the indirect-Y lowering. For a store the
; value byte lives in $a and must survive the pointer setup, so the $00/$01
; pointer pair is built via $x (LDX/STX, not LDA/STA) and the value reaches
; `STA ($00),Y` still in $a — no TXA. This proves placement is always
; correctness-safe: when the window can't hold a frame, nothing is promoted and
; the slow-but-correct path stands.

; CHECK: big:
; CHECK:     LDA #$01
; CHECK:     LDX #<big_local0
; CHECK:     STX $00
; CHECK:     LDX #>big_local0
; CHECK:     STX $01
; CHECK:     LDY #$00
; CHECK:     STA ($00),Y
; CHECK:     RTS

func @big : () -> void {
  frame_slot 0 : i32 @big_local0
  frame_slot 1 : i32 @big_local1
  frame_slot 2 : i32 @big_local2
  frame_slot 3 : i32 @big_local3
  frame_slot 4 : i32 @big_local4
  frame_slot 5 : i32 @big_local5
  frame_slot 6 : i32 @big_local6
  frame_slot 7 : i32 @big_local7
  frame_slot 8 : i32 @big_local8
  bb0():
    %0 : i16 = mem.frame_addr 0
    %1 : i8 = arith.constant 1
    mem.store.i8 %0, %1
    core.return
}
