; RUN: @iriec --target mos6502 --stop-after TwoAddressInstruction @file

; Checks the unified-MIR two-address instruction pass. After instruction
; selection, each `mos6502.adc` has a `(tied-def 0)` use that references a
; different vreg than its def[0]. This pass inserts an explicit `pseudo.copy`
; before each such adc to materialize the tied use as a fresh def of the
; def[0] vreg, so the register allocator can pick a single physreg for both
; ends.
;
; The inserted copies intentionally break strict-SSA — the same vreg
; (e.g. %33) is now defined twice, once by the inserted `pseudo.copy` and
; once by the `mos6502.adc` itself. That is exactly what tied-def semantics
; demand.
;
; The pass also propagates the tied use's register class to the def vreg
; (class ac in this case, supplied by mos6502.adc's OperandClasses).

; CHECK: func @TestFunction : (i32, i32) -> i32 {
; CHECK: bb0():
; CHECK:     [liveins: $a, $x, $zp2, $zp3, $zp4, $zp5, $zp6, $zp7]
; CHECK:     %3 : ac = pseudo.copy $a
; CHECK:     %4 : ac = pseudo.copy $x
; CHECK:     %5 : ac = pseudo.copy $zp2
; CHECK:     %6 : ac = pseudo.copy $zp3
; CHECK:     %7 : zp = pseudo.copy $zp4
; CHECK:     %8 : zp = pseudo.copy $zp5
; CHECK:     %9 : zp = pseudo.copy $zp6
; CHECK:     %10 : zp = pseudo.copy $zp7
; CHECK:     %32 : cc = mos6502.clc
; CHECK:     %33 : ac = pseudo.copy %3
; CHECK:     %33 : ac, %34 : cc = mos6502.adc %33(tied-def 0), %7, %32
; CHECK:     %35 : ac = pseudo.copy %4
; CHECK:     %35 : ac, %36 : cc = mos6502.adc %35(tied-def 0), %8, %34
; CHECK:     %37 : ac = pseudo.copy %5
; CHECK:     %37 : ac, %38 : cc = mos6502.adc %37(tied-def 0), %9, %36
; CHECK:     %39 : ac = pseudo.copy %6
; CHECK:     %39 : ac, %40 : cc = mos6502.adc %39(tied-def 0), %10, %38
; CHECK:     $a = pseudo.copy %33
; CHECK:     $x = pseudo.copy %35
; CHECK:     $zp2 = pseudo.copy %37
; CHECK:     $zp3 = pseudo.copy %39
; CHECK:     mos6502.rts implicit $a, implicit $x, implicit $zp2, implicit $zp3
; CHECK: }

func @TestFunction : (i32, i32) -> i32 {
bb0(%0 : i32, %1 : i32):
    %2 : i32 = arith.addi %0, %1
    core.return %2
}
