; RUN: @iriec --target mos6502 --start-at PhiElimination --stop-after PhiElimination @file

; bb0 loops to itself swapping its two parameters: new_p0 = p1, new_p1 = p0.
; The two assignments form a cycle (%0 := %1 and %1 := %0), so the pass must
; break it with a temporary:
;   %2 = copy %1    (save %1)
;   %1 = copy %0    (assign old %0 to %1)
;   %0 = copy %2    (assign saved %1 to %0)

; CHECK: func @swap \{
; CHECK:   bb0\(\):
; CHECK:     %2:Ac = GenericCopy %1:Ac
; CHECK:     %1:Ac = GenericCopy %0:Ac
; CHECK:     %0:Ac = GenericCopy %2:Ac
; CHECK:     GenericJump bb0
; CHECK: \}

func @swap {
  bb0(%0:Ac, %1:Ac):
    GenericJump bb0, %1:Ac, %0:Ac
}
