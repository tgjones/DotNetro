; RUN: @iriec --target mos6502 --stop-after Legalizer @file

; Verifies the artifact-combiner rule for pseudo.extract of pseudo.merge:
; when an extract picks out a sub-range that aligns exactly with one of the
; merge's parts (same bit offset, same width), the combiner replaces the
; extract's def with a direct reference to the matching part. The extract
; instruction is erased; the merge is erased too if it has no other users.
;
; In this test:
;   %2 : i16 = pseudo.merge %0 (i8), %1 (i8)   ; %0 → bits [0..8), %1 → bits [8..16)
;   %3 : i8  = pseudo.extract %2, 0            ; bits [0..8) → matches %0
;   %4 : i8  = pseudo.extract %2, 8            ; bits [8..16) → matches %1
; After combine: %3 → %0, %4 → %1, the merge and both extracts are erased.

; CHECK: func @TestExtractMerge : \(i8, i8\) -> void \{
; CHECK:   bb0\(\):
; CHECK:     \[liveins: \$a, \$x\]
; CHECK:     %0 : i8 = pseudo.copy \$a
; CHECK:     %1 : i8 = pseudo.copy \$x
; CHECK:     \$a = pseudo.copy %0
; CHECK:     \$x = pseudo.copy %1
; CHECK:     mos6502.jsr.abs @Use2, implicit \$a, implicit \$x
; CHECK:     pseudo.return
; CHECK: \}

func @TestExtractMerge : (i8, i8) -> void {
bb0(%0 : i8, %1 : i8):
    %2 : i16 = pseudo.merge %0, %1
    %3 : i8  = pseudo.extract %2, 0
    %4 : i8  = pseudo.extract %2, 8
    call.func @Use2, %3, %4
    core.return
}
