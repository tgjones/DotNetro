; RUN: @iriec --target mos6502 --stop-after PseudoExpansion @file

; Checks the unified-MIR pipeline output after the final pass —
; PseudoExpansion. By this point every `pseudo.copy` left by the register
; allocator (and untouched by CopyElimination + the target's AMS pass) has
; been lowered to a concrete MOS6502 move:
;   $reg = pseudo.copy $a    →  mos6502.sta.zp (when reg is a zero-page slot)
;   $a   = pseudo.copy $x    →  mos6502.txa
;   $a   = pseudo.copy $zpN  →  mos6502.lda.zp
;   $x   = pseudo.copy $zpN  →  mos6502.ldx.zp
;   $zpN = pseudo.copy $zpM  →  mos6502.lda.zp + mos6502.sta.zp (goes via $a)
;
; Only target opcodes and the closing rts remain — no `pseudo.*` or `core.*`.
; Note: where a zp→zp copy would clobber $a while $a still holds a live value
; (and at the return-value setup, whose $a output is consumed by the rts),
; MOS6502ParallelCopyPass reschedules the acyclic parallel copy: it evacuates the
; live $a value into a free scratch zp slot (here $zp8 / $zp9) and emits the
; $a-destined load last, so the lda+sta expansion no longer corrupts $a.

; CHECK: func @TestFunction : \(i32, i32\) -> i32 \{
; CHECK: bb0\(\):
; CHECK:     \[liveins: \$a, \$x, \$zp2, \$zp3, \$zp4, \$zp5, \$zp6, \$zp7\]
; CHECK:     \$c = mos6502.clc
; CHECK:     \$a, \$c = mos6502.adc.zp \$a, \$zp4, \$c
; CHECK:     \$zp4 = mos6502.sta.zp \$a
; CHECK:     \$a = mos6502.txa \$x
; CHECK:     \$a, \$c = mos6502.adc.zp \$a, \$zp5, \$c
; CHECK:     \$zp8 = mos6502.sta.zp \$a
; CHECK:     \$a = mos6502.lda.zp \$zp2
; CHECK:     \$zp9 = mos6502.sta.zp \$a
; CHECK:     \$a = mos6502.lda.zp \$zp8
; CHECK:     \$zp5 = mos6502.sta.zp \$a
; CHECK:     \$a = mos6502.lda.zp \$zp6
; CHECK:     \$zp2 = mos6502.sta.zp \$a
; CHECK:     \$a = mos6502.lda.zp \$zp9
; CHECK:     \$a, \$c = mos6502.adc.zp \$a, \$zp2, \$c
; CHECK:     \$zp6 = mos6502.sta.zp \$a
; CHECK:     \$a = mos6502.lda.zp \$zp3
; CHECK:     \$zp8 = mos6502.sta.zp \$a
; CHECK:     \$a = mos6502.lda.zp \$zp6
; CHECK:     \$zp2 = mos6502.sta.zp \$a
; CHECK:     \$a = mos6502.lda.zp \$zp7
; CHECK:     \$zp3 = mos6502.sta.zp \$a
; CHECK:     \$a = mos6502.lda.zp \$zp8
; CHECK:     \$a, \$c = mos6502.adc.zp \$a, \$zp3, \$c
; CHECK:     \$zp3 = mos6502.sta.zp \$a
; CHECK:     \$a = mos6502.lda.zp \$zp4
; CHECK:     \$x = mos6502.ldx.zp \$zp5
; CHECK:     mos6502.rts implicit \$a, implicit \$x, implicit \$zp2, implicit \$zp3
; CHECK: \}

func @TestFunction : (i32, i32) -> i32 {
bb0(%0 : i32, %1 : i32):
    %2 : i32 = arith.addi %0, %1
    core.return %2
}
