; RUN: @iriec --target mos6502 --stop-after Legalizer @file

; The legalizer normalizes every compare predicate to the canonical
; {eq, uge, slt} set the 6502 flags express directly (mirrors llvm-mos
; MOSLegalizerInfo::legalizeICmp), *consumer-independently*. Two moves reach the
; canonical set:
;   - negate (ne/ult/sge): invert the predicate and wrap the i1 result in an
;     arith.not (llvm-mos's buildNot). The consuming cf.cond_br is left untouched;
;     the instruction selector strips the not and swaps the branch's true/false
;     targets. (ugt/sle reach the set via an operand swap then a negate.)
;   - operand swap (ule/ugt/sle/sgt): reverse the predicate and the a/b operands.
; Predicates already in the set (eq/uge/slt) pass through untouched.
;
; This pins the predicate + operand order + the arith.not after normalization;
; the downstream asm is exercised by the *-MachineCode tests.

; ne → eq, result negated (edges unchanged).
; CHECK: func @Ne : (i8, i8) -> void {
; CHECK: bb0():
; CHECK:     [liveins: $a, $x]
; CHECK:     %0 : i8 = pseudo.copy $a
; CHECK:     %1 : i8 = pseudo.copy $x
; CHECK:     %3 : i1 = arith.cmpi eq, %0, %1
; CHECK:     %2 : i1 = arith.not %3
; CHECK:     cf.cond_br %2, bb1, bb2
func @Ne : (i8, i8) -> void {
bb0(%0 : i8, %1 : i8):
    %2 : i1 = arith.cmpi ne, %0, %1
    cf.cond_br %2, bb1, bb2
bb1(): core.return
bb2(): core.return
}

; ult → uge, result negated.
; CHECK: func @Ult : (i8, i8) -> void {
; CHECK: bb0():
; CHECK:     [liveins: $a, $x]
; CHECK:     %0 : i8 = pseudo.copy $a
; CHECK:     %1 : i8 = pseudo.copy $x
; CHECK:     %3 : i1 = arith.cmpi uge, %0, %1
; CHECK:     %2 : i1 = arith.not %3
; CHECK:     cf.cond_br %2, bb1, bb2
func @Ult : (i8, i8) -> void {
bb0(%0 : i8, %1 : i8):
    %2 : i1 = arith.cmpi ult, %0, %1
    cf.cond_br %2, bb1, bb2
bb1(): core.return
bb2(): core.return
}

; ugt → swap operands to ult, then negate to uge: uge %1, %0 + arith.not.
; CHECK: func @Ugt : (i8, i8) -> void {
; CHECK: bb0():
; CHECK:     [liveins: $a, $x]
; CHECK:     %0 : i8 = pseudo.copy $a
; CHECK:     %1 : i8 = pseudo.copy $x
; CHECK:     %3 : i1 = arith.cmpi uge, %1, %0
; CHECK:     %2 : i1 = arith.not %3
; CHECK:     cf.cond_br %2, bb1, bb2
func @Ugt : (i8, i8) -> void {
bb0(%0 : i8, %1 : i8):
    %2 : i1 = arith.cmpi ugt, %0, %1
    cf.cond_br %2, bb1, bb2
bb1(): core.return
bb2(): core.return
}

; ule → swap operands to uge: uge %1, %0, no negate.
; CHECK: func @Ule : (i8, i8) -> void {
; CHECK: bb0():
; CHECK:     [liveins: $a, $x]
; CHECK:     %0 : i8 = pseudo.copy $a
; CHECK:     %1 : i8 = pseudo.copy $x
; CHECK:     %2 : i1 = arith.cmpi uge, %1, %0
; CHECK:     cf.cond_br %2, bb1, bb2
func @Ule : (i8, i8) -> void {
bb0(%0 : i8, %1 : i8):
    %2 : i1 = arith.cmpi ule, %0, %1
    cf.cond_br %2, bb1, bb2
bb1(): core.return
bb2(): core.return
}

; sgt → swap operands to slt: slt %1, %0, no negate.
; CHECK: func @Sgt : (i8, i8) -> void {
; CHECK: bb0():
; CHECK:     [liveins: $a, $x]
; CHECK:     %0 : i8 = pseudo.copy $a
; CHECK:     %1 : i8 = pseudo.copy $x
; CHECK:     %2 : i1 = arith.cmpi slt, %1, %0
; CHECK:     cf.cond_br %2, bb1, bb2
func @Sgt : (i8, i8) -> void {
bb0(%0 : i8, %1 : i8):
    %2 : i1 = arith.cmpi sgt, %0, %1
    cf.cond_br %2, bb1, bb2
bb1(): core.return
bb2(): core.return
}

; sle → swap operands to sge, then negate to slt: slt %1, %0 + arith.not.
; CHECK: func @Sle : (i8, i8) -> void {
; CHECK: bb0():
; CHECK:     [liveins: $a, $x]
; CHECK:     %0 : i8 = pseudo.copy $a
; CHECK:     %1 : i8 = pseudo.copy $x
; CHECK:     %3 : i1 = arith.cmpi slt, %1, %0
; CHECK:     %2 : i1 = arith.not %3
; CHECK:     cf.cond_br %2, bb1, bb2
func @Sle : (i8, i8) -> void {
bb0(%0 : i8, %1 : i8):
    %2 : i1 = arith.cmpi sle, %0, %1
    cf.cond_br %2, bb1, bb2
bb1(): core.return
bb2(): core.return
}

; sge → negate to slt: slt %0, %1 + arith.not.
; CHECK: func @Sge : (i8, i8) -> void {
; CHECK: bb0():
; CHECK:     [liveins: $a, $x]
; CHECK:     %0 : i8 = pseudo.copy $a
; CHECK:     %1 : i8 = pseudo.copy $x
; CHECK:     %3 : i1 = arith.cmpi slt, %0, %1
; CHECK:     %2 : i1 = arith.not %3
; CHECK:     cf.cond_br %2, bb1, bb2
func @Sge : (i8, i8) -> void {
bb0(%0 : i8, %1 : i8):
    %2 : i1 = arith.cmpi sge, %0, %1
    cf.cond_br %2, bb1, bb2
bb1(): core.return
bb2(): core.return
}
