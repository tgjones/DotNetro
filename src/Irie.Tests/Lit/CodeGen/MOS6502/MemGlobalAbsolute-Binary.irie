; RUN: @iriec --target mos6502 --emit=asm @file
; RUN-bin: @iriec --target mos6502 --emit=bin --origin=0x1000 @file | @irie-mc --hex-dump

; A 16-bit load+store of a global resolves to ABSOLUTE addressing (lda/sta of the
; symbol directly), not a runtime zero-page pointer + (zp),Y. The high byte uses
; a symbol with a +1 offset (g+1), which must round-trip through asm text AND the
; binary encoder. (Stage A of notes/mos6502-absolute-addressing-plan.md.)

; CHECK: load_store_global:
; CHECK:     LDA g
; CHECK:     TAY
; CHECK:     LDA g+1
; CHECK:     TAX
; CHECK:     STY g
; CHECK:     STX g+1
; CHECK:     TYA
; CHECK:     RTS

; The low byte stays in $y and the high byte in $x, so the stores are STY/STX
; absolute directly (no transfer back through $a) — the value is read in place
; via the generic st.abs's Axy operand class, refined to sty.abs/stx.abs post-RA.
; Layout at $1000: the 16-byte function, then g (2 bytes) at $1010/$1011.
;   AD 10 10  LDA $1010 (g)        A8  TAY
;   AD 11 10  LDA $1011 (g+1)      AA  TAX     <- +1 offset applied
;   8C 10 10  STY $1010 (g)        8E 11 10  STX $1011 (g+1)
;   98  TYA   60  RTS
; CHECK-bin: 00000000: AD 10 10 A8 AD 11 10 AA  8C 10 10 8E 11 10 98 60
; CHECK-bin: 00000010: 00 00

global @g : i16 = bytes "\x00\x00"
func @load_store_global : () -> i16 {
bb0():
    %0 : i16 = mem.symbol @g
    %1 : i16 = mem.load.i16 %0
    mem.store.i16 %0, %1
    core.return %1
}
