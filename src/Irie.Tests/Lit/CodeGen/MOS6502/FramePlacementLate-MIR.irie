; RUN: @iriec --target mos6502-bbcmicro --stop-after MOS6502FramePlacement @file

; Proves frame placement happens LATE — post-register-allocation — exactly like
; llvm-mos's MOSZeroPageAlloc (which runs in addPrePEI, after RA, and only sets a
; stack-id attribute). The target-private MOS6502FramePlacementPass is added via
; AddPostRegisterAllocationPasses, so it runs after the call has already been
; lowered to mos6502.jsr.abs and after RA; this dump (stopped right after that
; pass, before the generic FrameAccessLoweringPass) shows:
;
;   * the placement decision recorded as an attribute on the frame_slot
;     (`stackid 1 offset <addr>`) — id 1 is MOS6502FrameStackIds.ZeroPage and the
;     offset is the absolute zero-page address ($70 = 112, $72 = 114);
;   * the access itself still ABSTRACT (mos6502.frame.store.byte) — addressing is
;     chosen only in the *next* pass, from this attribute;
;   * the call already lowered to mos6502.jsr.abs — i.e. we really are post-RA;
;   * the bottom-up colouring: @leaf (leaf, base 0) at $70, @caller (calls @leaf)
;     at $72 — disjoint, so @caller's slot survives the JSR;
;   * the store value carried in $a (no $x pin).

; CHECK: func @leaf : () -> void {
; CHECK:   frame_slot 0 : i16 @leaf_local0 stackid 1 offset 112
; CHECK: bb0():
; CHECK:     $a = pseudo.copy 7
; CHECK:     mos6502.frame.store.byte @leaf_local0, 0, $a, implicit-def $x, implicit-def $y, implicit-def $zp0, implicit-def $zp1

; CHECK: func @caller : () -> void {
; CHECK:   frame_slot 0 : i16 @caller_local0 stackid 1 offset 114
; CHECK: bb0():
; CHECK:     $a = pseudo.copy 3
; CHECK:     mos6502.frame.store.byte @caller_local0, 0, $a, implicit-def $x, implicit-def $y, implicit-def $zp0, implicit-def $zp1
; CHECK:     mos6502.jsr.abs @leaf, implicit-def $a, implicit-def $x, implicit-def $y, implicit-def $c, implicit-def $n, implicit-def $v, implicit-def $z, implicit-def $b, implicit-def $zp2, implicit-def $zp3, implicit-def $zp4, implicit-def $zp5, implicit-def $zp6, implicit-def $zp7, implicit-def $zp8, implicit-def $zp9, implicit-def $zp10, implicit-def $zp11, implicit-def $zp12, implicit-def $zp13, implicit-def $zp14, implicit-def $zp15, implicit-def $zp16, implicit-def $zp17, implicit-def $zp18, implicit-def $zp19

func @leaf : () -> void {
  frame_slot 0 : i16 @leaf_local0
  bb0():
    %0 : i16 = mem.frame_addr 0
    %1 : i8 = arith.constant 7
    mem.store.i8 %0, %1
    core.return
}

func @caller : () -> void {
  frame_slot 0 : i16 @caller_local0
  bb0():
    %0 : i16 = mem.frame_addr 0
    %1 : i8 = arith.constant 3
    mem.store.i8 %0, %1
    call.func @leaf
    core.return
}
