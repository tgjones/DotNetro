; RUN: @iriec --target mos6502 --stop-after InstructionSelector @file

; Checks instruction selection for mem.load.i8 / mem.store.i8 against an
; address produced by mem.symbol. The legalizer first lowers each typed
; mem.load.i8 / mem.store.i8 to a `mem.load.byte_at %p, 0` / `mem.store.byte_at`
; chain (offset is always 0 here — multi-byte chains land in step 9 / the
; MemLoadStoreI16 tests).
;
; Because the address resolves to a static symbol, isel selects absolute
; addressing:
;   - mos6502.lda.abs @hello loads the byte directly into $a;
;   - the loaded byte is routed through Anyi8 vregs so RA can park it;
;   - mos6502.sta.abs %v, @hello stores it back, with the value funnelled
;     through $a (Ac).
; No zero-page pointer pair and no Y register are materialised.

; CHECK: func @TestMemByte : \(\) -> void \{
; CHECK:   bb0\(\):
; CHECK:     %3 : ac = mos6502.lda.abs @hello
; CHECK:     %4 : any8 = pseudo.copy %3
; CHECK:     %5 : any8 = pseudo.copy %4
; CHECK:     %6 : ac = pseudo.copy %5
; CHECK:     mos6502.sta.abs %6, @hello
; CHECK:     mos6502.rts
; CHECK: \}

global @hello : i32 = bytes "Hi!"

func @TestMemByte : () -> void {
bb0():
    %0 : i16 = mem.symbol @hello
    %1 : i8  = mem.load.i8 %0
    mem.store.i8 %0, %1
    core.return
}
