; RUN: @iriec --target mos6502 --emit=asm @file

; End-to-end check for mem.load.i8 / mem.store.i8 through a mem.symbol
; address. Because the address resolves to a static symbol, isel selects
; absolute addressing (lda.abs / sta.abs @hello) — the single byte is loaded
; and stored directly, with no zero-page pointer pair and no Y register.

; CHECK: TestMemByte:
; CHECK:     LDA hello
; CHECK:     STA hello
; CHECK:     RTS

global @hello : i32 = bytes "Hi!"

func @TestMemByte : () -> void {
bb0():
    %0 : i16 = mem.symbol @hello
    %1 : i8  = mem.load.i8 %0
    mem.store.i8 %0, %1
    core.return
}
