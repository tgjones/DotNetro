; RUN: @iriec --target mos6502 --emit=asm @file

; End-to-end check for mem.load / mem.store through a *runtime* i16 pointer
; (an address vreg that is not a mem.symbol global). Two cases:
;
;   @LoadThroughPtr — load a byte through an i16 pointer parameter. The two
;     parameter bytes ($a = low, $x = high) are stored straight into the
;     indirect-Y scratch pair $00/$01 (no `LDA #<sym` materialisation), Y is
;     zeroed, and lda.indy dereferences it.
;
;   @StoreFieldAtOffset — the field-access shape: compute `ptr + 4` then store a
;     byte through the result. The 16-bit add narrows to a two-byte adc chain
;     whose merged result feeds the store's pointer setup. The offset constants
;     (4 and the 0 high byte) are materialised into the zero-page adc operands
;     via LDY #imm ; STY $zp, the pointer low/high (ptr+4) land in $y / $a, and
;     the indirect-Y pointer pair ($00/$01) is built from them — no $x↔$y copy
;     and no scavenger zero-page bounce.

; CHECK: LoadThroughPtr:
; CHECK:     STA $00
; CHECK:     STX $01
; CHECK:     LDY #$00
; CHECK:     LDA ($00),Y
; CHECK:     RTS
; CHECK:
; CHECK: StoreFieldAtOffset:
; CHECK:     CLC
; CHECK:     ADC #$04
; CHECK:     TAY
; CHECK:     TXA
; CHECK:     ADC #$00
; CHECK:     STY $00
; CHECK:     STA $01
; CHECK:     LDY #$00
; CHECK:     LDA $02
; CHECK:     STA ($00),Y
; CHECK:     RTS


func @LoadThroughPtr : (i16) -> i8 {
bb0(%0 : i16):
    %1 : i8 = mem.load.i8 %0
    core.return %1
}

func @StoreFieldAtOffset : (i16, i8) -> void {
bb0(%0 : i16, %1 : i8):
    %2 : i16 = arith.constant 4
    %3 : i16 = arith.addi %0, %2
    mem.store.i8 %3, %1
    core.return
}
