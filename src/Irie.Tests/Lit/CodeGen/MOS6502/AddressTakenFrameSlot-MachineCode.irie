; RUN: @iriec --target mos6502-bbcmicro --emit=asm @file

; Address-taken frame slot under the late-lowering design (Stage 2).
;
; @owner is a non-reentrant leaf-ish function whose i16 frame slot is both
; accessed directly in-function (mem.store.i8 / mem.load.i8) AND escaped — its
; address (mem.frame_addr 0) is passed as an i16 pointer argument to @sink.
;
; Stage 2: the slot stays in absolute memory (no zero-page promotion yet), so
; the in-function byte accesses lower — post-RA, via FrameAccessLoweringPass —
; to the absolute global + indirect-Y sequence, and the escaped address
; materialises as `LDA #<owner_local0` / `LDA #>owner_local0` on the SAME symbol
; (the slot has a single absolute home — no escape-driven split). Stage 3 will
; promote the slot to zero page and the in-function accesses become direct
; LDA/STA $70 while the escaped address still names the same symbol. This test
; pins down that the slot is a single location addressed consistently.

; CHECK: owner:
; CHECK:     LDX #\$04
; CHECK:     LDA #<owner_local0
; CHECK:     STA \$00
; CHECK:     LDA #>owner_local0
; CHECK:     STA \$01
; CHECK:     LDY #\$00
; CHECK:     TXA
; CHECK:     STA \(\$00\),Y
; CHECK:     LDA #<owner_local0
; CHECK:     STA \$00
; CHECK:     LDA #>owner_local0
; CHECK:     STA \$01
; CHECK:     LDY #\$00
; CHECK:     LDA \(\$00\),Y
; CHECK:     LDA #<owner_local0
; CHECK:     LDA #>owner_local0
; CHECK:     JSR sink
; CHECK:     RTS

func @sink : (i16) -> void {
  bb0(%0 : i16):
    core.return
}

func @owner : () -> void {
  frame_slot 0 : i16 @owner_local0
  bb0():
    %0 : i16 = mem.frame_addr 0
    %1 : i8 = arith.constant 4
    mem.store.i8 %0, %1
    %2 : i8 = mem.load.i8 %0
    call.func @sink, %0
    core.return
}
