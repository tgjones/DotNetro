; RUN: @iriec --target mos6502-bbcmicro --emit=asm @file

; Address-taken frame slot under the late-lowering design.
;
; @owner is a non-reentrant leaf-ish function whose i16 frame slot is both
; accessed directly in-function (mem.store.i8 / mem.load.i8) AND escaped — its
; address (mem.frame_addr 0) is passed as an i16 pointer argument to @sink.
;
; The slot is PROMOTED to zero page (the placement pass colours @owner's frame at
; the base of the window, $70) even though its address escapes. Faithful to
; llvm-mos's eliminateFrameIndex, the slot's symbol resolves to its zero-page
; address EVERYWHERE, so the slot has a SINGLE home: the in-function accesses
; lower to direct `STA $70` / `LDA $70`, and the escaped address materialises as
; `LDA #<owner_local0` / `LDA #>owner_local0` on the SAME symbol — which the
; binary encoder resolves to that same zero-page address (low $70, high $00),
; because the placement pass pins the slot's global to $70 (MirGlobal.FixedAddress)
; so it reserves no .bss storage. Placement is post-RA and the resolution happens
; late, at encode time; the escaped pointer never splits into a separate absolute
; home. This test fails if the slot were split or mis-placed.
;
; The escaped i16 address is passed per CC_MOS with the low byte in $a, high in
; $x; the low/high materialisations are sequenced through $y to avoid clobbering.

; CHECK: owner:
; CHECK:     LDA #\$04
; CHECK:     STA \$70
; CHECK:     LDA \$70
; CHECK:     LDA #<owner_local0
; CHECK:     TAY
; CHECK:     LDA #>owner_local0
; CHECK:     TAX
; CHECK:     TYA
; CHECK:     JSR sink
; CHECK:     RTS

func @sink : (i16) -> void {
  bb0(%0 : i16):
    core.return
}

func @owner : () -> void {
  frame_slot 0 : i16 @owner_local0
  bb0():
    %0 : i16 = mem.frame_addr 0
    %1 : i8 = arith.constant 4
    mem.store.i8 %0, %1
    %2 : i8 = mem.load.i8 %0
    call.func @sink, %0
    core.return
}
