; RUN: @iriec --target mos6502-bbcmicro --emit=bin @file | @irie-mc --hex-dump

; End-to-end BBC Micro DFS image verification: the same IntegerAdd32 input
; as IntegerAdd32-Binary.irie, packaged as a single-file .ssd disk image.
; Asserts the catalogue header (title, file name, load/exec/length/start
; sector) and the code body at sector 2.

; --- Sector 0: disk title chars 0-7 then file entry (7-char name + dir char) ---
;                  D  o  t  N  e  t  r  o   !  B  O  O  T  _  $
; CHECK: 00000000: 44 6F 74 4E 65 74 72 6F  21 42 4F 4F 54 20 20 24
; CHECK: 00000010: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000020: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000030: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000040: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000050: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000060: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000070: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000080: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000090: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000000A0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000000B0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000000C0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000000D0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000000E0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000000F0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000100: 00 00 00 00 00 08 20 03  00 20 00 20 16 00 00 02
; CHECK: 00000110: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000120: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000130: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000140: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000150: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000160: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000170: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000180: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000190: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000001A0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000001B0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000001C0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000001D0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000001E0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000001F0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000200: 18 65 04 A8 8A 65 05 AA  A5 02 65 06 85 02 A5 03
; CHECK: 00000210: 65 07 85 03 98 60 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000220: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000230: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000240: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000250: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000260: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000270: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000280: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 00000290: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000002A0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000002B0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000002C0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000002D0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000002E0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00
; CHECK: 000002F0: 00 00 00 00 00 00 00 00  00 00 00 00 00 00 00 00

; --- Sector 1: catalogue header + file metadata ---
; Byte layout at 0x100: title-cont(4), cycle, n*8=08, boot/sec-hi, total-sec-lo,
;   then file entry: load-lo load-hi exec-lo exec-hi len-lo len-hi packed-hi start-sec

; --- Sector 2: code begins (matches IntegerAdd32-Binary.irie) ---

func @TestFunction : (i32, i32) -> i32 {
bb0(%0 : i32, %1 : i32):
    %2 : i32 = arith.addi %0, %1
    core.return %2
}
