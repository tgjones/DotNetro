; RUN: @iriec --target mos6502 --run-pass CopyElimination @file

; Only the identity copy ($a = pseudo.copy $a) is removed.
; The non-identity copy ($a = pseudo.copy $x) and the mos6502.adc.zp instruction
; (a non-copy with two physical-register defs) are both left untouched.

; CHECK: func @mixed : () -> void {
; CHECK: bb0():
; CHECK:     $a = pseudo.copy $x
; CHECK:     $a, $c = mos6502.adc.zp $a, $zp4, $c
; CHECK: }

func @mixed : () -> void {
bb0():
    $0 = pseudo.copy $0
    $0 = pseudo.copy $1
    $0, $5 = mos6502.adc.zp $0, $16, $5
}
