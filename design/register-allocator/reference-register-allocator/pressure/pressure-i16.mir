--- |
  ; ModuleID = './pressure/pressure-i16.ll'
  source_filename = "./pressure/pressure-i16.c"
  target datalayout = "e-m:e-p:16:8-p1:8:8-i16:8-i32:8-i64:8-f32:8-f64:8-a:8-Fi8-n8"
  target triple = "mos-unknown-unknown"
  
  ; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none)
  define dso_local i16 @pressure_i16(i16 noundef %0, i16 noundef %1, i16 noundef %2, i16 noundef %3) local_unnamed_addr #0 {
    %5 = add nsw i16 %1, %0
    %6 = add nsw i16 %3, %2
    %7 = add nsw i16 %2, %0
    %8 = add nsw i16 %3, %1
    %9 = xor i16 %6, %5
    %10 = xor i16 %8, %7
    %11 = add nsw i16 %9, %10
    ret i16 %11
  }
  
  attributes #0 = { mustprogress nofree norecurse nosync nounwind willreturn memory(none) "frame-pointer"="all" "no-trapping-math"="true" "nonreentrant" "stack-protector-buffer-size"="8" }
  
  !llvm.module.flags = !{!0}
  !llvm.ident = !{!1}
  !llvm.errno.tbaa = !{!2}
  
  !0 = !{i32 7, !"frame-pointer", i32 2}
  !1 = !{!"clang version 23.0.0git (https://github.com/llvm-mos/llvm-mos.git c798c31416f72b395c658b5502d281a162387ab1)"}
  !2 = !{!3, !3, i64 0}
  !3 = !{!"int", !4, i64 0}
  !4 = !{!"omnipotent char", !5, i64 0}
  !5 = !{!"Simple C/C++ TBAA"}
...
---
name:            pressure_i16
alignment:       1
exposesReturnsTwice: false
legalized:       true
regBankSelected: true
selected:        true
failedISel:      false
tracksRegLiveness: true
hasWinCFI:       false
noPhis:          true
isSSA:           false
noVRegs:         true
hasFakeUses:     false
callsEHReturn:   false
callsUnwindInit: false
hasEHContTarget: false
hasEHScopes:     false
hasEHFunclets:   false
isOutlined:      false
debugInstrRef:   false
failsVerification: false
tracksDebugUserValues: true
registers:       []
liveins:         []
frameInfo:
  isFrameAddressTaken: false
  isReturnAddressTaken: false
  hasStackMap:     false
  hasPatchPoint:   false
  stackSize:       0
  offsetAdjustment: 0
  maxAlignment:    1
  adjustsStack:    false
  hasCalls:        false
  framePointerPolicy: all
  stackProtector:  ''
  functionContext: ''
  maxCallFrameSize: 4294967295
  cvBytesOfCalleeSavedRegisters: 0
  hasOpaqueSPAdjustment: false
  hasVAStart:      false
  hasMustTailInVarArgFunc: false
  hasTailCall:     false
  isCalleeSavedInfoValid: false
  localFrameSize:  0
fixedStack:      []
stack:           []
entry_values:    []
callSites:       []
debugValueSubstitutions: []
constants:       []
machineFunctionInfo: {}
body:             |
  bb.0 (%ir-block.4):
    liveins: $a, $x, $rc2, $rc3, $rc4, $rc5, $rc6, $rc7
  
    renamable $rc8 = COPY $a
    renamable $rc9 = COPY $x
    renamable $x = COPY $rc7
    renamable $c = LDImm1 0
    renamable $a = COPY renamable $rc2
    renamable $a, renamable $c, dead renamable $v = ADCImag8 killed renamable $a, renamable $rc8, killed renamable $c
    renamable $ylsb = LDImm1 0
    renamable $rc10lsb = COPY killed renamable $ylsb
    renamable $rc14 = COPY killed renamable $a
    renamable $a = COPY renamable $rc3
    renamable $a, dead renamable $c, dead renamable $v = ADCImag8 killed renamable $a, renamable $rc9, killed renamable $c
    renamable $rc13 = COPY killed renamable $a
    renamable $rc11 = COPY renamable $rc4
    renamable $a = COPY renamable $rc6
    renamable $rc7 = COPY renamable $rc5
    renamable $c = COPY renamable $rc10lsb
    renamable $a, renamable $c, dead renamable $v = ADCImag8 killed renamable $a, killed renamable $rc11, killed renamable $c
    renamable $rc12 = COPY killed renamable $a
    renamable $a = COPY renamable $x
    renamable $a, dead renamable $c, dead renamable $v = ADCImag8 killed renamable $a, killed renamable $rc7, killed renamable $c
    renamable $rc11 = COPY killed renamable $a
    renamable $c = COPY renamable $rc10lsb
    renamable $a = COPY killed renamable $rc4
    renamable $a, renamable $c, dead renamable $v = ADCImag8 killed renamable $a, killed renamable $rc8, killed renamable $c
    renamable $rc8 = COPY killed renamable $a
    renamable $a = COPY killed renamable $rc5
    renamable $a, dead renamable $c, dead renamable $v = ADCImag8 killed renamable $a, killed renamable $rc9, killed renamable $c
    renamable $rc7 = COPY killed renamable $a
    renamable $c = COPY renamable $rc10lsb
    renamable $a = COPY killed renamable $rc6
    renamable $a, renamable $c, dead renamable $v = ADCImag8 killed renamable $a, killed renamable $rc2, killed renamable $c
    renamable $y = COPY killed renamable $a
    renamable $a = COPY killed renamable $x
    renamable $a, dead renamable $c, dead renamable $v = ADCImag8 killed renamable $a, killed renamable $rc3, killed renamable $c
    renamable $rc3 = COPY killed renamable $a
    renamable $a = COPY killed renamable $y
    renamable $a = EORImag8 killed renamable $a, killed renamable $rc8
    renamable $rc2 = COPY killed renamable $a
    renamable $a = COPY killed renamable $rc12
    renamable $a = EORImag8 killed renamable $a, killed renamable $rc14
    renamable $rc6 = COPY killed renamable $a
    renamable $a = COPY killed renamable $rc11
    renamable $a = EORImag8 killed renamable $a, killed renamable $rc13
    renamable $rc4 = COPY killed renamable $a
    renamable $a = COPY killed renamable $rc3
    renamable $a = EORImag8 killed renamable $a, killed renamable $rc7
    renamable $rc3 = COPY killed renamable $a
    renamable $c = COPY killed renamable $rc10lsb
    renamable $a = COPY killed renamable $rc6
    renamable $a, renamable $c, dead renamable $v = ADCImag8 killed renamable $a, killed renamable $rc2, killed renamable $c
    renamable $y = COPY killed renamable $a
    renamable $a = COPY killed renamable $rc4
    renamable $a, dead renamable $c, dead renamable $v = ADCImag8 killed renamable $a, killed renamable $rc3, killed renamable $c
    $x = COPY killed renamable $a
    $a = COPY killed renamable $y
    RTS implicit $a, implicit $x
...
